<div class="px-6 md:px-10 py-10 bg-gray-100 min-h-screen">

  <!-- Search -->
  <div class="mb-8">
    <input id="collegeSearch" type="text"
           placeholder="Search colleges, departments, deans..."
           class="w-full border border-gray-300 rounded-xl px-6 py-4 bg-white focus:ring-2 focus:ring-green-700 focus:outline-none text-sm">
  </div>

  <!-- Header -->
  <div class="mb-8">
    <h2 class="text-2xl font-bold text-gray-900">Colleges & Departments</h2>
    <p class="text-sm text-gray-500 mt-0.5">University of Sharjah — College of Computing and Informatics</p>
  </div>

  <!-- Colleges Grid -->
  <div class="space-y-6">
    <% colleges.forEach(college => { %>
      <div class="college-card bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

        <!-- College Header -->
        <div class="bg-gradient-to-r <%= college.color %> px-6 py-5 flex items-center justify-between">
          <div>
            <h3 class="text-white font-bold text-lg"><%= college.name %></h3>
            <p class="text-white/80 text-sm mt-0.5">Dean: <%= college.dean %></p>
          </div>
          <div class="text-right">
            <p class="text-white/60 text-xs font-medium uppercase tracking-wide">Departments</p>
            <p class="text-white font-bold text-2xl"><%= college.departments.length %></p>
          </div>
        </div>

        <!-- Departments -->
        <div class="p-6">
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
            <% college.departments.forEach(dept => { %>
              <div class="bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 hover:bg-gray-100 transition">
                <p class="text-sm font-medium text-gray-800"><%= dept %></p>
              </div>
            <% }) %>
          </div>
        </div>

      </div>
    <% }) %>
  </div>

  <!-- Summary Footer -->
  <div class="mt-8 bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <p class="text-3xl font-bold text-gray-900"><%= colleges.length %></p>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mt-1">Colleges</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900"><%= colleges.reduce((s, c) => s + c.departments.length, 0) %></p>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mt-1">Departments</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-gray-900"><%= colleges.length %></p>
        <p class="text-xs text-gray-400 font-medium uppercase tracking-wide mt-1">Deans</p>
      </div>
      <div>
        <a href="/faculty-members" class="text-green-800 hover:underline font-medium text-sm">View Faculty &rarr;</a>
        <p class="text-xs text-gray-400 mt-1">Manage all faculty</p>
      </div>
    </div>
  </div>

</div>

<script>
  document.getElementById("collegeSearch").addEventListener("keyup", function() {
    const val = this.value.toLowerCase();
    document.querySelectorAll(".college-card").forEach(card => {
      card.style.display = card.innerText.toLowerCase().includes(val) ? "" : "none";
    });
  });
</script>
