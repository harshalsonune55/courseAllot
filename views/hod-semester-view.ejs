<style>
  .sem-tab.active  { background: #1e3a5f; color: #fff; border-color: #1e3a5f; }
  .sem-tab         { transition: background .2s, color .2s; }
  .prog-tab.active { background: #1e3a5f; color: #fff; }
  .prog-tab        { transition: background .2s, color .2s; }
</style>

<div class="px-6 md:px-10 py-10 bg-gray-100 min-h-screen">

  <!-- Search -->
  <div class="mb-8">
    <input id="semSearch" type="text"
           placeholder="Search courses, faculty..."
           class="w-full border border-gray-300 rounded-xl px-6 py-4 bg-white focus:ring-2 focus:ring-green-700 focus:outline-none text-sm">
  </div>

  <!-- Header -->
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Courses</h2>
      <p class="text-sm text-gray-500 mt-0.5">Browse and assign courses by program and semester</p>
    </div>
    <div class="flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-4 py-2 text-sm text-gray-600 shadow-sm">
      Academic Year 2024–25
    </div>
  </div>

  <!-- Program Tabs -->
  <div class="flex gap-2 mb-6">
    <button onclick="switchProg('mm')" id="prog-mm"
            class="prog-tab active px-5 py-2.5 rounded-xl text-sm font-semibold border border-blue-900 text-blue-900">
      Multimedia
    </button>
    <button onclick="switchProg('cs')" id="prog-cs"
            class="prog-tab px-5 py-2.5 rounded-xl text-sm font-semibold border border-gray-300 text-gray-600 bg-white">
      Computer Science
    </button>
  </div>

  <!-- ========== MULTIMEDIA ========== -->
  <div id="panel-mm">

    <div class="flex gap-2 mb-5">
      <button onclick="switchSem('mm','fall')" id="sem-mm-fall"
              class="sem-tab active px-5 py-2 rounded-xl text-sm font-semibold border border-blue-900 text-white bg-blue-900">
        Fall <span class="opacity-70 font-normal text-xs">(<%= multimediaCourses.fall.length %> courses)</span>
      </button>
      <button onclick="switchSem('mm','spring')" id="sem-mm-spring"
              class="sem-tab px-5 py-2 rounded-xl text-sm font-semibold border border-gray-300 text-gray-600 bg-white">
        Spring <span class="opacity-70 font-normal text-xs">(<%= multimediaCourses.spring.length %> courses)</span>
      </button>
    </div>

    <!-- MM Fall -->
    <div id="panel-mm-fall" class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-400 text-xs uppercase tracking-wide">
            <th class="px-5 py-3 text-left font-medium">#</th>
            <th class="px-5 py-3 text-left font-medium">Course Name</th>
            <th class="px-5 py-3 text-left font-medium">Semester</th>
            <th class="px-5 py-3 text-right font-medium">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% multimediaCourses.fall.forEach((course, idx) => { %>
            <tr class="course-row hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3.5 text-gray-400 text-xs"><%= idx + 1 %></td>
              <td class="px-5 py-3.5 font-medium text-gray-800"><%= course %></td>
              <td class="px-5 py-3.5"><span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-full">Fall</span></td>
              <td class="px-5 py-3.5 text-right">
                <button class="assign-btn bg-green-800 hover:bg-green-700 text-white text-xs font-semibold px-4 py-1.5 rounded-lg transition"
                        data-course="<%= course %>">
                  Assign Faculty
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- MM Spring -->
    <div id="panel-mm-spring" class="hidden bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-400 text-xs uppercase tracking-wide">
            <th class="px-5 py-3 text-left font-medium">#</th>
            <th class="px-5 py-3 text-left font-medium">Course Name</th>
            <th class="px-5 py-3 text-left font-medium">Semester</th>
            <th class="px-5 py-3 text-right font-medium">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% multimediaCourses.spring.forEach((course, idx) => { %>
            <tr class="course-row hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3.5 text-gray-400 text-xs"><%= idx + 1 %></td>
              <td class="px-5 py-3.5 font-medium text-gray-800"><%= course %></td>
              <td class="px-5 py-3.5"><span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded-full">Spring</span></td>
              <td class="px-5 py-3.5 text-right">
                <button class="assign-btn bg-green-800 hover:bg-green-700 text-white text-xs font-semibold px-4 py-1.5 rounded-lg transition"
                        data-course="<%= course %>">
                  Assign Faculty
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- ========== COMPUTER SCIENCE ========== -->
  <div id="panel-cs" class="hidden">

    <div class="flex gap-2 mb-5">
      <button onclick="switchSem('cs','fall')" id="sem-cs-fall"
              class="sem-tab active px-5 py-2 rounded-xl text-sm font-semibold border border-blue-900 text-white bg-blue-900">
        Fall <span class="opacity-70 font-normal text-xs">(<%= csCourses.fall.length %> courses)</span>
      </button>
      <button onclick="switchSem('cs','spring')" id="sem-cs-spring"
              class="sem-tab px-5 py-2 rounded-xl text-sm font-semibold border border-gray-300 text-gray-600 bg-white">
        Spring <span class="opacity-70 font-normal text-xs">(<%= csCourses.spring.length %> courses)</span>
      </button>
    </div>

    <!-- CS Fall -->
    <div id="panel-cs-fall" class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-400 text-xs uppercase tracking-wide">
            <th class="px-5 py-3 text-left font-medium">#</th>
            <th class="px-5 py-3 text-left font-medium">Course Name</th>
            <th class="px-5 py-3 text-left font-medium">Semester</th>
            <th class="px-5 py-3 text-right font-medium">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% csCourses.fall.forEach((course, idx) => { %>
            <tr class="course-row hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3.5 text-gray-400 text-xs"><%= idx + 1 %></td>
              <td class="px-5 py-3.5 font-medium text-gray-800"><%= course %></td>
              <td class="px-5 py-3.5"><span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-full">Fall</span></td>
              <td class="px-5 py-3.5 text-right">
                <button class="assign-btn bg-green-800 hover:bg-green-700 text-white text-xs font-semibold px-4 py-1.5 rounded-lg transition"
                        data-course="<%= course %>">
                  Assign Faculty
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- CS Spring -->
    <div id="panel-cs-spring" class="hidden bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-400 text-xs uppercase tracking-wide">
            <th class="px-5 py-3 text-left font-medium">#</th>
            <th class="px-5 py-3 text-left font-medium">Course Name</th>
            <th class="px-5 py-3 text-left font-medium">Semester</th>
            <th class="px-5 py-3 text-right font-medium">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% csCourses.spring.forEach((course, idx) => { %>
            <tr class="course-row hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3.5 text-gray-400 text-xs"><%= idx + 1 %></td>
              <td class="px-5 py-3.5 font-medium text-gray-800"><%= course %></td>
              <td class="px-5 py-3.5"><span class="bg-green-100 text-green-800 text-xs font-medium px-2.5 py-0.5 rounded-full">Spring</span></td>
              <td class="px-5 py-3.5 text-right">
                <button class="assign-btn bg-green-800 hover:bg-green-700 text-white text-xs font-semibold px-4 py-1.5 rounded-lg transition"
                        data-course="<%= course %>">
                  Assign Faculty
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

</div>

<!-- ===== ASSIGN FACULTY MODAL ===== -->
<div id="assignFacultyModal"
     class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center hidden z-50">

  <div class="bg-white w-[600px] max-h-[80vh] rounded-2xl shadow-2xl overflow-hidden flex flex-col">

    <!-- Header -->
    <div class="px-6 pt-6 pb-4 border-b border-gray-100 shrink-0">
      <h3 class="text-lg font-bold text-gray-900">Assign Faculty</h3>
      <p class="text-sm text-gray-500 mt-0.5">Course: <span id="assignCourseName" class="font-semibold text-gray-800"></span></p>
    </div>

    <!-- Faculty List -->
    <div class="overflow-y-auto flex-1 divide-y divide-gray-100" id="facultyListContainer">
      <% if (facultyList && facultyList.length > 0) { %>
        <% facultyList.forEach(faculty => { %>
          <div class="faculty-assign-row px-6 py-4 flex items-center justify-between gap-4 hover:bg-gray-50 transition"
               data-name="<%= faculty.fullName.toLowerCase() %>"
               data-rec="<%= JSON.stringify(faculty.recommendedCourses || []) %>"
               data-preferred="<%= JSON.stringify(faculty.preferredCourses || []) %>">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-blue-950 rounded-full flex items-center justify-center text-white text-sm font-bold shrink-0">
                <%= faculty.fullName.charAt(0).toUpperCase() %>
              </div>
              <div>
                <p class="font-medium text-gray-800 text-sm"><%= faculty.fullName %></p>
                <p class="text-xs text-gray-400"><%= faculty.department || 'No dept' %></p>
                <div class="flex items-center gap-2 mt-1">
                  <span class="match-badge text-xs font-semibold px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">Match: —</span>
                  <span class="pref-badge hidden text-xs font-semibold px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">Preferred</span>
                </div>
              </div>
            </div>
            <form action="/assign-course" method="POST" class="shrink-0">
              <input type="hidden" name="facultyId" value="<%= faculty._id %>">
              <input type="hidden" name="courseName" class="courseNameInput" value="">
              <button type="submit"
                      class="bg-blue-950 hover:bg-blue-900 text-white text-xs font-semibold px-4 py-2 rounded-xl transition">
                Assign
              </button>
            </form>
          </div>
        <% }) %>
      <% } else { %>
        <p class="px-6 py-8 text-sm text-gray-400">No faculty members found. <a href="/add-faculty" class="text-blue-700 underline">Add faculty</a></p>
      <% } %>
    </div>

    <!-- Footer -->
    <div class="px-6 py-4 border-t border-gray-100 shrink-0">
      <button id="closeModalBtn"
              class="w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium py-2.5 rounded-xl text-sm transition">
        Close
      </button>
    </div>
  </div>
</div>

<script>
  // ─── Program switching ───────────────────��────────────────────────
  function switchProg(prog) {
    ['mm','cs'].forEach(function(p) {
      document.getElementById('panel-' + p).classList.toggle('hidden', p !== prog);
      var btn = document.getElementById('prog-' + p);
      if (p === prog) {
        btn.classList.add('active','bg-blue-900','text-white','border-blue-900');
        btn.classList.remove('bg-white','text-gray-600','border-gray-300');
      } else {
        btn.classList.remove('active','bg-blue-900','text-white','border-blue-900');
        btn.classList.add('bg-white','text-gray-600','border-gray-300');
      }
    });
  }

  // ─── Semester switching ───────────────────────────────────────────
  function switchSem(prog, sem) {
    ['fall','spring'].forEach(function(s) {
      document.getElementById('panel-' + prog + '-' + s).classList.toggle('hidden', s !== sem);
      var btn = document.getElementById('sem-' + prog + '-' + s);
      if (s === sem) {
        btn.classList.add('active','bg-blue-900','text-white','border-blue-900');
        btn.classList.remove('bg-white','text-gray-600','border-gray-300');
      } else {
        btn.classList.remove('active','bg-blue-900','text-white','border-blue-900');
        btn.classList.add('bg-white','text-gray-600','border-gray-300');
      }
    });
  }

  // ─── Assign Faculty Modal ────────────────────────���────────────────
  var modal = document.getElementById('assignFacultyModal');

  // Open when any .assign-btn is clicked
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.assign-btn');
    if (btn) {
      openAssignModal(btn.dataset.course);
    }
  });

  // Close button
  document.getElementById('closeModalBtn').addEventListener('click', function() {
    modal.classList.add('hidden');
  });

  // Click outside to close
  modal.addEventListener('click', function(e) {
    if (e.target === modal) modal.classList.add('hidden');
  });

  function openAssignModal(courseName) {
    // Set course name in header
    document.getElementById('assignCourseName').textContent = courseName;

    // Set all hidden form inputs
    document.querySelectorAll('.courseNameInput').forEach(function(inp) {
      inp.value = courseName;
    });

    // Update match badges
    document.querySelectorAll('.faculty-assign-row').forEach(function(row) {
      var rec  = [];
      var pref = [];
      try { rec  = JSON.parse(row.getAttribute('data-rec')  || '[]'); } catch(e) {}
      try { pref = JSON.parse(row.getAttribute('data-preferred') || '[]'); } catch(e) {}

      var found = rec.find(function(r) { return r.course === courseName; });
      var score = found ? found.score : 0;

      var badge = row.querySelector('.match-badge');
      badge.textContent = 'Match: ' + score + '%';
      badge.className = 'match-badge text-xs font-semibold px-2 py-0.5 rounded-full ' +
        (score >= 70 ? 'bg-green-100 text-green-700' :
         score >= 40 ? 'bg-yellow-100 text-yellow-700' :
                       'bg-gray-100 text-gray-500');

      var prefBadge = row.querySelector('.pref-badge');
      if (pref.indexOf(courseName) !== -1) {
        prefBadge.classList.remove('hidden');
      } else {
        prefBadge.classList.add('hidden');
      }
    });

    // Sort: preferred first, then by score desc
    var container = document.getElementById('facultyListContainer');
    var rows = Array.prototype.slice.call(container.querySelectorAll('.faculty-assign-row'));
    rows.sort(function(a, b) {
      var aRec  = []; var bRec  = [];
      var aPref = []; var bPref = [];
      try { aRec  = JSON.parse(a.getAttribute('data-rec')       || '[]'); } catch(e) {}
      try { bRec  = JSON.parse(b.getAttribute('data-rec')       || '[]'); } catch(e) {}
      try { aPref = JSON.parse(a.getAttribute('data-preferred') || '[]'); } catch(e) {}
      try { bPref = JSON.parse(b.getAttribute('data-preferred') || '[]'); } catch(e) {}

      var aScore = ((aRec.find(function(r){return r.course===courseName;})||{score:0}).score);
      var bScore = ((bRec.find(function(r){return r.course===courseName;})||{score:0}).score);
      var aPf = aPref.indexOf(courseName) !== -1 ? 1 : 0;
      var bPf = bPref.indexOf(courseName) !== -1 ? 1 : 0;
      if (bPf !== aPf) return bPf - aPf;
      return bScore - aScore;
    });
    rows.forEach(function(r) { container.appendChild(r); });

    modal.classList.remove('hidden');
  }

  // ─── Search ───────────────────────────────────────────────────────
  document.getElementById('semSearch').addEventListener('keyup', function() {
    var val = this.value.toLowerCase().trim();
    document.querySelectorAll('.course-row').forEach(function(row) {
      row.style.display = (!val || row.textContent.toLowerCase().indexOf(val) !== -1) ? '' : 'none';
    });
  });
</script>
