<style>
  .sem-tab.active  { background: #1e3a5f; color: #fff; }
  .sem-tab         { transition: background .2s, color .2s; }
  .sem-panel       { display: none; }
  .sem-panel.show  { display: block; }

  @keyframes panelIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .sem-panel.show { animation: panelIn .25s ease both; }
</style>

<div class="px-6 md:px-12 py-10 bg-gray-100 min-h-screen">

  <!-- Search -->
  <div class="mb-8">
    <input id="semSearch" type="text"
           placeholder="Search courses, credits, faculty..."
           class="w-full border border-gray-300 rounded-xl px-6 py-4 bg-white focus:ring-2 focus:ring-green-700 focus:outline-none text-sm">
  </div>

  <!-- Header -->
  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Semester View</h2>
      <p class="text-sm text-gray-500 mt-0.5">All courses organised by semester — Computer Science & Engineering</p>
    </div>
    <div class="flex items-center gap-2 bg-white border border-gray-200 rounded-xl px-4 py-2 text-sm text-gray-600 shadow-sm">
      <svg class="w-4 h-4 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
      </svg>
      Academic Year 2024–25
    </div>
  </div>

  <!-- Summary stats -->
  <%
    const semesters = [
      {
        label: "Semester 1",
        short: "SEM 1",
        color: "from-blue-900 to-blue-700",
        badge: "bg-blue-100 text-blue-800",
        courses: [
          { name: "Engineering Mathematics I",     code: "MA101", credits: 4, type: "Core",     faculty: "Dr. Ramesh Patil"    },
          { name: "Physics",                        code: "PH101", credits: 3, type: "Core",     faculty: "Dr. Sunita Joshi"    },
          { name: "Programming Fundamentals",       code: "CS101", credits: 4, type: "Core",     faculty: "Prof. Anil Kumar"    },
          { name: "English Communication",          code: "EN101", credits: 2, type: "Elective", faculty: "Mrs. Priya Sharma"   },
          { name: "Engineering Drawing",            code: "ME101", credits: 2, type: "Lab",      faculty: "Prof. Rakesh Mehta"  }
        ]
      },
      {
        label: "Semester 2",
        short: "SEM 2",
        color: "from-indigo-700 to-indigo-500",
        badge: "bg-indigo-100 text-indigo-800",
        courses: [
          { name: "Engineering Mathematics II",     code: "MA201", credits: 4, type: "Core",     faculty: "Dr. Ramesh Patil"    },
          { name: "Data Structures",                code: "CS201", credits: 4, type: "Core",     faculty: "Prof. Sneha Desai"   },
          { name: "Digital Electronics",            code: "EC201", credits: 3, type: "Core",     faculty: "Dr. Vivek Kulkarni"  },
          { name: "Statistics & Probability",       code: "MA202", credits: 3, type: "Core",     faculty: "Dr. Meena Iyer"      },
          { name: "Technical Writing",              code: "EN201", credits: 2, type: "Elective", faculty: "Mrs. Priya Sharma"   }
        ]
      },
      {
        label: "Semester 3",
        short: "SEM 3",
        color: "from-violet-700 to-violet-500",
        badge: "bg-violet-100 text-violet-800",
        courses: [
          { name: "Database Management",            code: "CS301", credits: 4, type: "Core",     faculty: "Prof. Anil Kumar"    },
          { name: "Computer Networks",              code: "CS302", credits: 4, type: "Core",     faculty: "Dr. Vivek Kulkarni"  },
          { name: "Algorithms",                     code: "CS303", credits: 4, type: "Core",     faculty: "Prof. Sneha Desai"   },
          { name: "Software Engineering",           code: "CS304", credits: 3, type: "Core",     faculty: "Dr. Anita Rao"       },
          { name: "Operating Systems",              code: "CS305", credits: 3, type: "Core",     faculty: "Prof. Deepak Nair"   }
        ]
      },
      {
        label: "Semester 4",
        short: "SEM 4",
        color: "from-purple-700 to-purple-500",
        badge: "bg-purple-100 text-purple-800",
        courses: [
          { name: "Machine Learning",               code: "CS401", credits: 4, type: "Core",     faculty: "Dr. Anita Rao"       },
          { name: "Web Technologies",               code: "CS402", credits: 3, type: "Core",     faculty: "Prof. Rohit Gupta"   },
          { name: "Project Management",             code: "MG401", credits: 3, type: "Elective", faculty: "Dr. Kavita Singh"    },
          { name: "Linear Algebra",                 code: "MA401", credits: 3, type: "Core",     faculty: "Dr. Meena Iyer"      },
          { name: "Mini Project",                   code: "CS403", credits: 2, type: "Lab",      faculty: "Prof. Deepak Nair"   }
        ]
      },
      {
        label: "Semester 5",
        short: "SEM 5",
        color: "from-green-800 to-green-600",
        badge: "bg-green-100 text-green-800",
        courses: [
          { name: "Artificial Intelligence",        code: "CS501", credits: 4, type: "Core",     faculty: "Dr. Anita Rao"       },
          { name: "Cloud Computing",                code: "CS502", credits: 3, type: "Elective", faculty: "Prof. Rohit Gupta"   },
          { name: "Big Data Analytics",             code: "CS503", credits: 4, type: "Core",     faculty: "Dr. Siddharth Bose"  },
          { name: "Entrepreneurship",               code: "MG501", credits: 2, type: "Elective", faculty: "Dr. Kavita Singh"    },
          { name: "Research Methodology",           code: "RS501", credits: 2, type: "Elective", faculty: "Dr. Sunita Joshi"    }
        ]
      },
      {
        label: "Semester 6",
        short: "SEM 6",
        color: "from-teal-700 to-teal-500",
        badge: "bg-teal-100 text-teal-800",
        courses: [
          { name: "Cybersecurity",                  code: "CS601", credits: 4, type: "Core",     faculty: "Dr. Vivek Kulkarni"  },
          { name: "Leadership & Team Management",   code: "MG601", credits: 2, type: "Elective", faculty: "Dr. Kavita Singh"    },
          { name: "Deep Learning",                  code: "CS602", credits: 4, type: "Elective", faculty: "Dr. Siddharth Bose"  },
          { name: "Mobile App Development",         code: "CS603", credits: 3, type: "Elective", faculty: "Prof. Rohit Gupta"   },
          { name: "Capstone Project",               code: "CS604", credits: 6, type: "Project",  faculty: "All Faculty"         }
        ]
      }
    ];

    const totalCourses = semesters.reduce((s, sem) => s + sem.courses.length, 0);
    const totalCredits = semesters.reduce((s, sem) => s + sem.courses.reduce((sc, c) => sc + c.credits, 0), 0);
    const coreCount    = semesters.reduce((s, sem) => s + sem.courses.filter(c => c.type === "Core").length, 0);
    const electCount   = semesters.reduce((s, sem) => s + sem.courses.filter(c => c.type !== "Core").length, 0);
  %>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Total Courses</p>
      <p class="text-3xl font-bold text-gray-900 mt-1"><%= totalCourses %></p>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Total Credits</p>
      <p class="text-3xl font-bold text-gray-900 mt-1"><%= totalCredits %></p>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Core Courses</p>
      <p class="text-3xl font-bold text-blue-900 mt-1"><%= coreCount %></p>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Electives / Labs</p>
      <p class="text-3xl font-bold text-green-700 mt-1"><%= electCount %></p>
    </div>
  </div>

  <!-- Semester tabs -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden" id="semesterMain">

    <!-- Tab bar -->
    <div class="flex overflow-x-auto border-b border-gray-100 scrollbar-none" id="semTabs">
      <% semesters.forEach((sem, idx) => { %>
        <button
          class="sem-tab shrink-0 px-5 py-4 text-sm font-semibold text-gray-500 hover:text-gray-800 border-b-2 border-transparent hover:border-gray-300 transition-all whitespace-nowrap
                 <%= idx === 0 ? 'border-b-2 !border-blue-900 !text-blue-900' : '' %>"
          onclick="switchSem(<%= idx %>)"
          id="tab-<%= idx %>">
          <%= sem.short %> <span class="ml-1.5 text-xs font-normal opacity-60"><%= sem.courses.length %> courses</span>
        </button>
      <% }); %>
    </div>

    <!-- Panels -->
    <% semesters.forEach((sem, idx) => { %>
      <div class="sem-panel px-6 py-6 <%= idx === 0 ? 'show' : '' %>" id="panel-<%= idx %>">

        <!-- Semester header -->
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br <%= sem.color %> flex items-center justify-center text-white text-sm font-bold">
              <%= idx + 1 %>
            </div>
            <div>
              <h3 class="font-bold text-gray-900 text-lg"><%= sem.label %></h3>
              <p class="text-xs text-gray-400">
                <%= sem.courses.reduce((s, c) => s + c.credits, 0) %> credits &middot;
                <%= sem.courses.length %> courses
              </p>
            </div>
          </div>
          <span class="<%= sem.badge %> text-xs font-semibold px-3 py-1 rounded-full">
            <%= sem.courses.filter(c => c.type === 'Core').length %> Core &middot;
            <%= sem.courses.filter(c => c.type !== 'Core').length %> Elective/Lab
          </span>
        </div>

        <!-- Courses table (desktop) -->
        <div class="hidden md:block rounded-xl border border-gray-100 overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 text-gray-400 text-xs uppercase tracking-wide">
                <th class="px-5 py-3 text-left font-medium">Code</th>
                <th class="px-5 py-3 text-left font-medium">Course Name</th>
                <th class="px-5 py-3 text-left font-medium">Credits</th>
                <th class="px-5 py-3 text-left font-medium">Type</th>
                <th class="px-5 py-3 text-left font-medium">Faculty</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% sem.courses.forEach(course => { %>
                <tr class="course-row hover:bg-gray-50 transition-colors">
                  <td class="px-5 py-3.5">
                    <span class="font-mono text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded"><%= course.code %></span>
                  </td>
                  <td class="px-5 py-3.5 font-medium text-gray-800"><%= course.name %></td>
                  <td class="px-5 py-3.5">
                    <span class="inline-flex items-center gap-1 text-gray-600">
                      <svg class="w-3.5 h-3.5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                      <%= course.credits %>
                    </span>
                  </td>
                  <td class="px-5 py-3.5">
                    <% if (course.type === 'Core') { %>
                      <span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded-full">Core</span>
                    <% } else if (course.type === 'Lab') { %>
                      <span class="bg-orange-100 text-orange-700 text-xs font-medium px-2.5 py-0.5 rounded-full">Lab</span>
                    <% } else if (course.type === 'Project') { %>
                      <span class="bg-purple-100 text-purple-700 text-xs font-medium px-2.5 py-0.5 rounded-full">Project</span>
                    <% } else { %>
                      <span class="bg-green-100 text-green-700 text-xs font-medium px-2.5 py-0.5 rounded-full">Elective</span>
                    <% } %>
                  </td>
                  <td class="px-5 py-3.5 text-gray-500"><%= course.faculty %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>

        <!-- Courses cards (mobile) -->
        <div class="md:hidden space-y-3">
          <% sem.courses.forEach(course => { %>
            <div class="course-row bg-gray-50 rounded-xl p-4 border border-gray-100">
              <div class="flex items-center justify-between mb-1">
                <span class="font-mono text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded"><%= course.code %></span>
                <% if (course.type === 'Core') { %>
                  <span class="bg-blue-100 text-blue-800 text-xs px-2.5 py-0.5 rounded-full">Core</span>
                <% } else if (course.type === 'Lab') { %>
                  <span class="bg-orange-100 text-orange-700 text-xs px-2.5 py-0.5 rounded-full">Lab</span>
                <% } else if (course.type === 'Project') { %>
                  <span class="bg-purple-100 text-purple-700 text-xs px-2.5 py-0.5 rounded-full">Project</span>
                <% } else { %>
                  <span class="bg-green-100 text-green-700 text-xs px-2.5 py-0.5 rounded-full">Elective</span>
                <% } %>
              </div>
              <p class="font-semibold text-gray-800 text-sm mt-1"><%= course.name %></p>
              <div class="flex items-center justify-between mt-2 text-xs text-gray-400">
                <span><%= course.faculty %></span>
                <span class="flex items-center gap-1">
                  <svg class="w-3 h-3 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                  <%= course.credits %> credits
                </span>
              </div>
            </div>
          <% }); %>
        </div>

      </div>
    <% }); %>

  </div>
</div>

<script>
  /* ---- tab switching ---- */
  const tabCount = <%= semesters.length %>;

  function switchSem(idx) {
    for (let i = 0; i < tabCount; i++) {
      const tab   = document.getElementById("tab-" + i);
      const panel = document.getElementById("panel-" + i);

      if (i === idx) {
        tab.classList.add("!border-blue-900", "!text-blue-900");
        panel.classList.add("show");
      } else {
        tab.classList.remove("!border-blue-900", "!text-blue-900");
        panel.classList.remove("show");
      }
    }
  }

  /* ---- search (filters across all semesters) ---- */
  document.getElementById("semSearch").addEventListener("keyup", function() {
    const val = this.value.toLowerCase().trim();

    if (!val) {
      // restore current tab view
      document.querySelectorAll(".course-row").forEach(r => r.style.display = "");
      return;
    }

    // when searching, show ALL panels so results appear
    for (let i = 0; i < tabCount; i++) {
      document.getElementById("panel-" + i).classList.add("show");
    }

    document.querySelectorAll(".course-row").forEach(row => {
      row.style.display = row.innerText.toLowerCase().includes(val) ? "" : "none";
    });
  });
</script>
