<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Faculty Login — CAS</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: translateX(16px); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .form-panel { animation: fadeIn .4s cubic-bezier(.4,0,.2,1) both; }

    @keyframes patternFloat {
      0%, 100% { transform: translate(0,0) rotate(0deg); }
      50%       { transform: translate(6px,-8px) rotate(2deg); }
    }
    .deco { animation: patternFloat 7s ease-in-out infinite; }

    input:focus { outline: none; }
    .input-wrap:focus-within label { color: #1e3a8a; }
  </style>
</head>
<body class="min-h-screen bg-gray-50 flex items-center justify-center p-4">

  <div class="w-full max-w-4xl bg-white rounded-3xl shadow-2xl overflow-hidden flex min-h-[560px]">

    <!-- ===== LEFT BRAND PANEL ===== -->
    <div class="hidden md:flex flex-col justify-between w-[42%] bg-gradient-to-br from-blue-950 to-blue-800 p-10 relative overflow-hidden">

      <!-- decorative circles -->
      <div class="deco absolute -top-16 -right-16 w-64 h-64 rounded-full bg-white/5"></div>
      <div class="absolute bottom-20 -left-20 w-80 h-80 rounded-full bg-white/5"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-40 h-40 rounded-full bg-white/5"></div>

      <!-- logo -->
      <div class="relative z-10">
        <div class="w-12 h-12 bg-white/15 rounded-xl flex items-center justify-center ring-1 ring-white/20 mb-8">
          <img src="/images/image.png" alt="CAS" class="w-8 h-8 object-contain">
        </div>
        <h1 class="text-3xl font-bold text-white leading-tight">Welcome<br>back</h1>
        <p class="text-blue-200 text-sm mt-3 leading-relaxed">Sign in to manage your course<br>allocations and AI recommendations.</p>
      </div>

      <!-- bottom quote -->
      <div class="relative z-10">
        <div class="flex items-start gap-3 bg-white/10 rounded-2xl p-4">
          <svg class="w-5 h-5 text-blue-300 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
          <p class="text-blue-100 text-xs leading-relaxed">AI-powered matching helps the right faculty get the right courses.</p>
        </div>
      </div>

    </div>

    <!-- ===== RIGHT FORM PANEL ===== -->
    <div class="flex-1 flex flex-col justify-center px-8 md:px-12 py-10 form-panel">

      <!-- mobile logo -->
      <div class="flex items-center gap-3 mb-8 md:hidden">
        <div class="w-9 h-9 bg-blue-950 rounded-xl flex items-center justify-center">
          <img src="/images/image.png" alt="" class="w-6 h-6 object-contain">
        </div>
        <span class="font-bold text-gray-900">CAS</span>
      </div>

      <h2 class="text-2xl font-bold text-gray-900 mb-1">Faculty Sign In</h2>
      <p class="text-gray-400 text-sm mb-8">Enter your credentials to continue</p>

      <!-- error -->
      <% if (error) { %>
        <div class="flex items-center gap-3 bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm mb-6">
          <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <%= error %>
        </div>
      <% } %>

      <form action="/login-faculty" method="POST" class="space-y-5" onsubmit="handleSubmit(this)">

        <!-- username -->
        <div class="input-wrap">
          <label class="block text-sm font-medium text-gray-600 mb-1.5 transition-colors">Username or Email</label>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </span>
            <input type="text" name="identifier" required autocomplete="username"
                   placeholder="Enter username or email"
                   class="w-full border border-gray-200 bg-gray-50 rounded-xl pl-10 pr-4 py-3 text-sm focus:border-blue-900 focus:ring-2 focus:ring-blue-900/10 focus:bg-white transition-all">
          </div>
        </div>

        <!-- password -->
        <div class="input-wrap">
          <div class="flex justify-between items-center mb-1.5">
            <label class="text-sm font-medium text-gray-600 transition-colors">Password</label>
            <a href="/reset-password" class="text-xs text-blue-900 hover:underline font-medium">Forgot password?</a>
          </div>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </span>
            <input type="password" name="password" id="passwordInput" required autocomplete="current-password"
                   placeholder="Enter your password"
                   class="w-full border border-gray-200 bg-gray-50 rounded-xl pl-10 pr-12 py-3 text-sm focus:border-blue-900 focus:ring-2 focus:ring-blue-900/10 focus:bg-white transition-all">
            <button type="button" onclick="togglePwd('passwordInput', 'eyeIcon')"
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600 transition-colors p-1">
              <svg id="eyeIcon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- submit -->
        <button type="submit" id="submitBtn"
                class="w-full bg-blue-950 hover:bg-blue-900 text-white font-semibold py-3 rounded-xl transition-all flex items-center justify-center gap-2 text-sm mt-2">
          Sign In
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
          </svg>
        </button>

      </form>

      <p class="text-center text-sm text-gray-400 mt-8">
        Don't have an account?
        <a href="/signup-faculty" class="text-blue-900 font-semibold hover:underline ml-1">Create account</a>
      </p>

      <p class="text-center text-xs text-gray-300 mt-3">
        <a href="/" class="hover:text-gray-500 transition-colors">← Back to role selection</a>
      </p>

    </div>
  </div>

  <script>
    function togglePwd(inputId, iconId) {
      const input = document.getElementById(inputId);
      const icon  = document.getElementById(iconId);
      const show  = input.type === 'password';
      input.type = show ? 'text' : 'password';
      icon.innerHTML = show
        ? `<path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>`
        : `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`;
    }

    function handleSubmit(form) {
      const btn = document.getElementById('submitBtn');
      btn.disabled = true;
      btn.innerHTML = `<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/></svg> Signing in…`;
    }
  </script>
</body>
</html>
