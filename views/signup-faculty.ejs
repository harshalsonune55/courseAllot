<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CAS - Faculty Sign Up</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="relative flex items-center justify-center min-h-screen bg-cover bg-center"
      style="background-image: url('/images/opdp.jpg');">

  <div class="absolute inset-0 bg-black bg-opacity-60"></div>

  <div class="relative z-10 bg-white/90 backdrop-blur-md w-[520px] rounded-3xl shadow-2xl p-10">

    <!-- Logo -->
    <div class="flex justify-center mb-6">
      <div class="w-24 h-24 bg-blue-950 rounded-3xl flex items-center justify-center shadow-lg overflow-hidden">
        <img src="/images/imageco.png" alt="CAS" class="w-16 h-16 object-contain">
      </div>
    </div>

    <h1 class="text-3xl font-bold text-center mb-1">CAS</h1>
    <p class="text-center text-gray-500 mb-8 text-sm">Create your Faculty Account</p>

    <% if(error){ %>
      <div class="bg-red-100 text-red-700 p-3 rounded-xl mb-4 text-sm text-center">
        <%= error %>
      </div>
    <% } %>

    <form action="/faculty-signup" method="POST" class="space-y-4">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
        <input type="text" name="fullName" placeholder="e.g. Dr. John Smith" required
          class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-700">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <input type="email"
          name="email"
          placeholder="name@sharjah.ac.ae"
          required
          pattern="^[a-zA-Z0-9._%+-]+@sharjah\.ac\.ae$"
          title="Email must be in format: name@sharjah.ac.ae"
          class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-700">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Username</label>
        <input type="text" name="username" placeholder="Choose a username" required
          class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-700">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
        <input type="password" name="password" placeholder="Min. 6 characters" required
          class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-700">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
        <input type="password" name="confirmPassword" placeholder="Repeat password" required
          class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-700">
      </div>

      <div class="flex gap-4 pt-2">
        <a href="/faculty-login"
           class="w-1/2 bg-gray-100 text-center py-3 rounded-xl font-medium text-sm hover:bg-gray-200 transition flex items-center justify-center">
          &larr; Back
        </a>
        <button type="submit"
          class="w-1/2 bg-blue-950 text-white py-3 rounded-xl font-medium text-sm hover:bg-blue-900 transition">
          Create Account
        </button>
      </div>

    </form>

  </div>

  <script>
    const emailInput = document.querySelector("input[name='email']");
    emailInput.addEventListener("input", function () {
      if (!emailInput.value.endsWith("@sharjah.ac.ae")) {
        emailInput.setCustomValidity("Email must be a valid sharjah.ac.ae email");
      } else {
        emailInput.setCustomValidity("");
      }
    });
  </script>

</body>
</html>
