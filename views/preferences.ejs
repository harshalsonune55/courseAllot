<style>
  .course-item.selected {
    border-color: #1e3a8a;
    background: #eff6ff;
  }
</style>

<div class="px-6 md:px-16 py-10 bg-gray-100 min-h-screen">

  <!-- Search -->
  <div class="mb-8">
    <input id="prefSearch" type="text"
           placeholder="Search courses..."
           class="w-full border border-gray-300 rounded-xl px-6 py-4 bg-white focus:ring-2 focus:ring-blue-600 focus:outline-none text-sm">
  </div>

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Course Preferences</h2>
      <p class="text-sm text-gray-500 mt-0.5">Select the courses you prefer to teach. These will be visible to your HOD.</p>
    </div>
    <span id="selectedCount" class="text-sm font-semibold text-blue-700 bg-blue-50 border border-blue-200 px-4 py-1.5 rounded-full">
      <%= data.preferredCourses.length %> selected
    </span>
  </div>

  <form action="/update-preferences" method="POST" id="prefsForm">

    <!-- Multimedia Courses -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm mb-6">
      <div class="px-6 pt-5 pb-3 border-b border-gray-100">
        <h3 class="font-bold text-gray-900">Multimedia Courses</h3>
      </div>

      <div class="p-6">
        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Fall Semester</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2 mb-6">
          <% multimediaCourses.fall.forEach(course => { %>
            <%
              const isSelected = data.preferredCourses.includes(course);
              const aiRec = data.recommendations.find(r => r.course === course);
            %>
            <label class="course-item flex items-center gap-3 border border-gray-200 rounded-xl px-4 py-3 cursor-pointer hover:bg-gray-50 transition select-none <%= isSelected ? 'selected' : '' %>">
              <input type="checkbox" name="preferredCourses" value="<%= course %>"
                     <%= isSelected ? 'checked' : '' %>
                     onchange="updateCount(this)"
                     class="w-4 h-4 rounded border-gray-300 text-blue-700 focus:ring-blue-500 shrink-0">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-800 leading-tight"><%= course %></p>
                <% if (aiRec) { %>
                  <p class="text-xs text-green-700 mt-0.5">AI Match: <%= aiRec.score %>%</p>
                <% } %>
              </div>
            </label>
          <% }) %>
        </div>

        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Spring Semester</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2">
          <% multimediaCourses.spring.forEach(course => { %>
            <%
              const isSelected = data.preferredCourses.includes(course);
              const aiRec = data.recommendations.find(r => r.course === course);
            %>
            <label class="course-item flex items-center gap-3 border border-gray-200 rounded-xl px-4 py-3 cursor-pointer hover:bg-gray-50 transition select-none <%= isSelected ? 'selected' : '' %>">
              <input type="checkbox" name="preferredCourses" value="<%= course %>"
                     <%= isSelected ? 'checked' : '' %>
                     onchange="updateCount(this)"
                     class="w-4 h-4 rounded border-gray-300 text-blue-700 focus:ring-blue-500 shrink-0">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-800 leading-tight"><%= course %></p>
                <% if (aiRec) { %>
                  <p class="text-xs text-green-700 mt-0.5">AI Match: <%= aiRec.score %>%</p>
                <% } %>
              </div>
            </label>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Computer Science Courses -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm mb-8">
      <div class="px-6 pt-5 pb-3 border-b border-gray-100">
        <h3 class="font-bold text-gray-900">Computer Science Courses</h3>
      </div>

      <div class="p-6">
        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Fall Semester</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2 mb-6">
          <% csCourses.fall.forEach(course => { %>
            <%
              const isSelected = data.preferredCourses.includes(course);
              const aiRec = data.recommendations.find(r => r.course === course);
            %>
            <label class="course-item flex items-center gap-3 border border-gray-200 rounded-xl px-4 py-3 cursor-pointer hover:bg-gray-50 transition select-none <%= isSelected ? 'selected' : '' %>">
              <input type="checkbox" name="preferredCourses" value="<%= course %>"
                     <%= isSelected ? 'checked' : '' %>
                     onchange="updateCount(this)"
                     class="w-4 h-4 rounded border-gray-300 text-blue-700 focus:ring-blue-500 shrink-0">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-800 leading-tight"><%= course %></p>
                <% if (aiRec) { %>
                  <p class="text-xs text-green-700 mt-0.5">AI Match: <%= aiRec.score %>%</p>
                <% } %>
              </div>
            </label>
          <% }) %>
        </div>

        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Spring Semester</h4>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-2">
          <% csCourses.spring.forEach(course => { %>
            <%
              const isSelected = data.preferredCourses.includes(course);
              const aiRec = data.recommendations.find(r => r.course === course);
            %>
            <label class="course-item flex items-center gap-3 border border-gray-200 rounded-xl px-4 py-3 cursor-pointer hover:bg-gray-50 transition select-none <%= isSelected ? 'selected' : '' %>">
              <input type="checkbox" name="preferredCourses" value="<%= course %>"
                     <%= isSelected ? 'checked' : '' %>
                     onchange="updateCount(this)"
                     class="w-4 h-4 rounded border-gray-300 text-blue-700 focus:ring-blue-500 shrink-0">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-gray-800 leading-tight"><%= course %></p>
                <% if (aiRec) { %>
                  <p class="text-xs text-green-700 mt-0.5">AI Match: <%= aiRec.score %>%</p>
                <% } %>
              </div>
            </label>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Save Button -->
    <div class="sticky bottom-0 bg-white/90 backdrop-blur border-t border-gray-200 px-6 py-4 -mx-6 md:-mx-16 flex items-center justify-between gap-4">
      <p class="text-sm text-gray-500">
        <span id="saveCount" class="font-semibold text-gray-800"><%= data.preferredCourses.length %></span> course<span id="savePlural"><%= data.preferredCourses.length !== 1 ? 's' : '' %></span> selected
      </p>
      <div class="flex gap-3">
        <button type="button" onclick="clearAll()"
                class="px-5 py-2.5 border border-gray-300 text-gray-700 rounded-xl text-sm font-medium hover:bg-gray-50 transition">
          Clear All
        </button>
        <button type="submit"
                class="px-6 py-2.5 bg-blue-950 hover:bg-blue-900 text-white rounded-xl text-sm font-semibold transition">
          Save Preferences
        </button>
      </div>
    </div>

  </form>

</div>

<script>
  function updateCount(checkbox) {
    const label = checkbox.closest('label');
    if (checkbox.checked) {
      label.classList.add('selected');
    } else {
      label.classList.remove('selected');
    }
    refreshCountDisplay();
  }

  function refreshCountDisplay() {
    const count = document.querySelectorAll('input[name="preferredCourses"]:checked').length;
    document.getElementById('selectedCount').innerText = count + ' selected';
    document.getElementById('saveCount').innerText = count;
    document.getElementById('savePlural').innerText = count !== 1 ? 's' : '';
  }

  function clearAll() {
    document.querySelectorAll('input[name="preferredCourses"]').forEach(cb => {
      cb.checked = false;
      cb.closest('label').classList.remove('selected');
    });
    refreshCountDisplay();
  }

  document.getElementById('prefSearch').addEventListener('keyup', function() {
    const val = this.value.toLowerCase();
    document.querySelectorAll('.course-item').forEach(item => {
      item.style.display = item.innerText.toLowerCase().includes(val) ? '' : 'none';
    });
  });
</script>
