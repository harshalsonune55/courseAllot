<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>CAS Dashboard</title>
  <link href="/css/output.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <style>
    @keyframes fadeIn {
      from { opacity: 0; transform: scale(0.97) translateY(6px); }
      to   { opacity: 1; transform: scale(1)    translateY(0);   }
    }
    .modal-enter { animation: fadeIn 0.2s ease-out both; }

    /* underline slide-in for active nav link */
    .nav-underline {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: #1e3a8a;
      border-radius: 2px 2px 0 0;
    }
  </style>
</head>
<body class="bg-gray-100 font-sans">

<% if (typeof currentPage !== 'undefined' && currentPage !== 'auth') { %>

<!-- ===== NAVBAR ===== -->
<nav class="bg-white border-b border-gray-200 sticky top-0 z-40">
  <div class="px-6 md:px-10 flex items-center justify-between h-16">

    <!-- Left: logo + links -->
    <div class="flex items-center gap-6 h-full">

      <!-- Brand -->
      <a href="/home" class="flex items-center gap-2.5 shrink-0">
        <span class="w-9 h-9 rounded-lg overflow-hidden bg-gray-900 flex items-center justify-center">
          <img src="/images/image.png" alt="CAS" class="w-full h-full object-cover">
        </span>
        <span class="font-bold text-gray-900 text-sm hidden md:block tracking-wide">Course Allocation</span>
      </a>

      <div class="hidden md:block h-6 w-px bg-gray-200"></div>

      <!-- Nav links -->
      <div class="hidden md:flex items-center h-full gap-0.5">
        <%
          const navLinks = [
            { href: '/home',          label: 'Dashboard',     icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0h6', page: 'dashboard'    },
            { href: '/upload-cv',     label: 'Upload CV',     icon: 'M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12',                         page: 'upload'       },
            { href: '/allocations',   label: 'Allocations',   icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2', page: 'allocations'  },
            { href: '/notifications', label: 'Notifications', icon: 'M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9', page: 'notifications'}
          ];
        %>
        <% navLinks.forEach(link => { %>
          <a href="<%= link.href %>"
             class="relative flex items-center gap-1.5 h-16 px-4 text-sm font-medium transition-colors
                    <%= currentPage === link.page ? 'text-blue-900' : 'text-gray-500 hover:text-gray-900' %>">
            <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="<%= link.icon %>"/>
            </svg>
            <%= link.label %>
            <% if (currentPage === link.page) { %>
              <span class="nav-underline"></span>
            <% } %>
          </a>
        <% }); %>
      </div>
    </div>

    <!-- Right: profile -->
    <% if (user) { %>
    <button onclick="openProfileModal()"
            class="flex items-center gap-2.5 px-3 py-2 rounded-xl hover:bg-gray-50 border border-transparent hover:border-gray-200 transition-all group">
      <div class="w-8 h-8 bg-gradient-to-br from-blue-900 to-blue-600 text-white rounded-full flex items-center justify-center text-sm font-bold shrink-0 ring-2 ring-white">
        <%= user.fullName ? user.fullName.charAt(0).toUpperCase() : '?' %>
      </div>
      <div class="text-left hidden sm:block">
        <p class="text-sm font-semibold text-gray-800 leading-tight"><%= user.fullName %></p>
        <p class="text-xs text-gray-400 leading-tight"><%= user.role %> &middot; <%= user.department || 'No Dept' %></p>
      </div>
      <svg class="w-3.5 h-3.5 text-gray-400 hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </button>
    <% } %>

  </div>
</nav>

<% } %>

<%- body %>

<!-- ===== PROFILE VIEW MODAL ===== -->
<% if (user) { %>
<div id="profileModal"
     class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center hidden z-50"
     onclick="handleOverlayClick(event, 'profileModal')">

  <div class="modal-enter bg-white w-[460px] rounded-2xl shadow-2xl overflow-hidden">

    <!-- header band -->
    <div class="h-20 bg-gradient-to-r from-blue-900 to-blue-700 relative">
      <button onclick="closeProfileModal()"
              class="absolute top-4 right-4 w-8 h-8 rounded-full bg-white/20 hover:bg-white/30 flex items-center justify-center text-white transition">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <!-- avatar (overlaps header) -->
    <div class="-mt-10 flex flex-col items-center px-6 pb-2">
      <div class="w-20 h-20 bg-gradient-to-br from-green-700 to-green-500 rounded-full ring-4 ring-white flex items-center justify-center text-white text-3xl font-bold shadow-lg">
        <%= user.fullName ? user.fullName.charAt(0).toUpperCase() : '?' %>
      </div>
      <h3 class="mt-3 text-lg font-bold text-gray-900"><%= user.fullName %></h3>
      <span class="mt-1 text-xs font-medium bg-green-100 text-green-700 px-3 py-0.5 rounded-full"><%= user.role %></span>
    </div>

    <!-- info rows -->
    <div class="px-6 pb-2 mt-2 space-y-0 divide-y divide-gray-100">
      <div class="flex justify-between py-3 text-sm">
        <span class="text-gray-400 font-medium">Email</span>
        <span class="text-gray-700 font-medium"><%= user.email %></span>
      </div>
      <div class="flex justify-between py-3 text-sm">
        <span class="text-gray-400 font-medium">Department</span>
        <span class="text-gray-700 font-medium"><%= user.department || 'Not Set' %></span>
      </div>
      <div class="flex justify-between py-3 text-sm">
        <span class="text-gray-400 font-medium">Phone</span>
        <span class="text-gray-700 font-medium"><%= user.phone || 'Not Set' %></span>
      </div>
      <div class="flex justify-between py-3 text-sm">
        <span class="text-gray-400 font-medium">Member Since</span>
        <span class="text-gray-700 font-medium"><%= user.createdAt ? new Date(user.createdAt).toDateString() : '—' %></span>
      </div>
    </div>

    <!-- actions -->
    <div class="px-6 py-5 flex flex-col gap-3">
      <div class="flex gap-3">
        <button onclick="openEditProfile()"
                class="flex-1 flex items-center justify-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-3 rounded-xl transition text-sm">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
          Edit Profile
        </button>
        <button onclick="closeProfileModal()"
                class="flex-1 bg-blue-900 hover:bg-blue-800 text-white font-medium py-3 rounded-xl transition text-sm">
          Close
        </button>
      </div>
      <a href="/logout"
         class="flex items-center justify-center gap-2 w-full bg-red-50 hover:bg-red-100 text-red-600 font-medium py-3 rounded-xl transition text-sm border border-red-100">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
        Logout
      </a>
    </div>

  </div>
</div>
<% } %>

<!-- ===== EDIT PROFILE MODAL ===== -->
<% if (user) { %>
<div id="editProfileModal"
     class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center hidden z-50"
     onclick="handleOverlayClick(event, 'editProfileModal')">

  <div class="modal-enter bg-white w-[500px] rounded-2xl shadow-2xl overflow-hidden">

    <!-- header -->
    <div class="px-6 pt-6 pb-4 flex items-center justify-between border-b border-gray-100">
      <div class="flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
        </div>
        <h2 class="text-lg font-bold text-gray-900">Edit Profile</h2>
      </div>
      <button onclick="closeEditProfile()"
              class="w-8 h-8 rounded-full hover:bg-gray-100 flex items-center justify-center transition">
        <svg class="w-4 h-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <form action="/update-profile" method="POST" class="px-6 py-5 space-y-4">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Full Name</label>
        <input type="text" name="fullName" value="<%= user.fullName %>" required
               class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Email</label>
        <input type="email" name="email" value="<%= user.email %>" readonly
               class="w-full border border-gray-200 bg-gray-50 rounded-xl px-4 py-3 text-sm text-gray-400 cursor-not-allowed">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Department</label>
        <select name="department"
                class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition bg-white">
          <option value="">Select Department</option>
          <% ['Business Administration','Engineering','Health Sciences','Computing and Informatics','Sciences'].forEach(dept => { %>
            <option value="<%= dept %>" <%= user.department === dept ? 'selected' : '' %>><%= dept %></option>
          <% }); %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Phone</label>
        <input type="text" name="phone" value="<%= user.phone || '' %>"
               class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition">
      </div>

      <div class="flex gap-3 pt-2">
        <button type="button" onclick="closeEditProfile()"
                class="flex-1 border border-gray-300 text-gray-700 py-3 rounded-xl text-sm font-medium hover:bg-gray-50 transition">
          Cancel
        </button>
        <button type="submit"
                class="flex-1 bg-green-700 text-white py-3 rounded-xl text-sm font-medium hover:bg-green-800 transition">
          Save Changes
        </button>
      </div>

    </form>
  </div>
</div>
<% } %>

<script>
  const profileModal = document.getElementById("profileModal");
  const editModal    = document.getElementById("editProfileModal");

  function openProfileModal()  { profileModal.classList.remove("hidden"); }
  function closeProfileModal() { profileModal.classList.add("hidden"); }

  function openEditProfile() {
    profileModal.classList.add("hidden");
    editModal.classList.remove("hidden");
  }
  function closeEditProfile() { editModal.classList.add("hidden"); }

  function handleOverlayClick(e, id) {
    if (e.target.id === id) {
      document.getElementById(id).classList.add("hidden");
    }
  }
</script>

</body>
</html>
