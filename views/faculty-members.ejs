<div class="p-10">


    <div class="mb-8">
      <input
  id="searchFaculty"
  type="text"
  placeholder="Search faculty, email, course..."
  class="w-full border-2 border-gray-300 rounded-xl px-6 py-4 focus:ring-2 focus:ring-blue-600 focus:outline-none"
/>
    </div>
  

    <div class="flex justify-between items-center mb-8">
      <div>
        <h2 class="text-3xl font-bold">Faculty Members</h2>
        <p class="text-gray-600">Browse faculty by department</p>
      </div>
  
      <a href="/add-faculty"
   class="bg-blue-950 text-white px-6 py-3 rounded-xl font-medium hover:bg-blue-900 inline-block">
  + Add Faculty
</a>
    </div>
  

    <div class="bg-gray-100 border rounded-xl p-4 mb-8">
      <h3 class="text-xl font-semibold">
        Computer Science - <%= facultyList.length %> Faculty Members
      </h3>
    </div>
  

    <div class="grid grid-cols-2 gap-8">
  
      <% facultyList.forEach(faculty => { %>
  
        <div class="faculty-card bg-white border-2 border-gray-800 rounded-2xl p-6">
  
          <div class="flex items-center gap-6">
  
            <div class="bg-blue-950 w-20 h-20 rounded-full flex items-center justify-center text-white text-2xl">
              👤
            </div>
  
            <div>
              <h4 class="text-xl font-bold"><%= faculty.fullName %></h4>
              <p class="text-gray-600"><%= faculty.email %></p>
  
              <div class="mt-3 flex gap-3 flex-wrap">
  
                <% if (faculty.recommendedCourses && faculty.recommendedCourses.length > 0) { %>
  
                  <span class="bg-blue-950 text-white px-3 py-1 rounded-lg text-sm">
                    <%= faculty.recommendedCourses[0].course %>
                  </span>
  
                  <span class="bg-green-700 text-white px-3 py-1 rounded-lg text-sm">
                    CV Verified ✓
                  </span>
  
                <% } else { %>
  
                  <span class="bg-gray-400 text-white px-3 py-1 rounded-lg text-sm">
                    CV Not Uploaded
                  </span>
  
                <% } %>
  
              </div>
  
            </div>
  
          </div>
          <div class="mt-6">
            <button 
              onclick="openAssignModal('<%= faculty._id %>', '<%= faculty.fullName %>')"
              class="w-full bg-blue-950 text-white py-2 rounded-xl hover:bg-blue-900">
              ✨ Assign Course
            </button>
          </div>
  
        </div>
  
      <% }) %>
  
    </div>
  
  </div>
  <div id="assignModal"
     class="fixed inset-0 bg-black/40 flex items-center justify-center hidden z-50">

  <div class="bg-white w-[500px] rounded-2xl p-8 shadow-xl">

    <h2 class="text-2xl font-bold mb-6">Assign Course</h2>

    <p class="mb-4 text-gray-600">
      Assigning to: <span id="facultyName" class="font-semibold"></span>
    </p>

    <form action="/assign-course" method="POST" class="space-y-4">

      <input type="hidden" name="facultyId" id="facultyIdInput">

      <div>
        <label class="block mb-2">Course Name</label>
        <select name="courseName"
  class="w-full border-2 border-gray-300 px-4 py-3 rounded-xl"
  required>

  <option value="">-- Select Course --</option>

  <% courses.forEach(course => { %>
    <option value="<%= course %>"><%= course %></option>
  <% }) %>

</select>
      </div>

      <div>
        <label class="block mb-2">Reason (Optional)</label>
        <textarea name="reason"
          class="w-full border-2 border-gray-300 px-4 py-3 rounded-xl"
          placeholder="Why assigning this course..."></textarea>
      </div>

      <div class="flex gap-4 mt-6">
        <button type="button" onclick="closeAssignModal()"
          class="w-1/2 border py-3 rounded-xl">
          Cancel
        </button>

        <button type="submit"
          class="w-1/2 bg-blue-950 text-white py-3 rounded-xl">
          Assign
        </button>
      </div>

    </form>

  </div>
</div>

  <script>
    const searchInput = document.getElementById("searchFaculty");
  
    searchInput.addEventListener("keyup", function () {
      const value = this.value.toLowerCase();
  
      const cards = document.querySelectorAll(".faculty-card");
  
      cards.forEach(card => {
        const text = card.innerText.toLowerCase();
  
        if (text.includes(value)) {
          card.style.display = "block"; 
        } else {
          card.style.display = "none";
        }
      });
    });
  </script>
  <script>
    const assignModal = document.getElementById("assignModal");
  
    function openAssignModal(id, name) {
      document.getElementById("facultyIdInput").value = id;
      document.getElementById("facultyName").innerText = name;
  
      assignModal.classList.remove("hidden");
    }
  
    function closeAssignModal() {
      assignModal.classList.add("hidden");
    }
  </script>