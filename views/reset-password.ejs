

    <div class="flex items-center justify-center min-h-screen w-full">
  
      <div class="bg-white w-full max-w-md p-10 rounded-2xl shadow-xl">
  
        <h2 class="text-2xl font-bold mb-6 text-center">
          Reset Password 🔐
        </h2>
  
        <% if (error) { %>
          <div class="bg-red-100 text-red-700 p-3 rounded mb-4 text-center">
            <%= error %>
          </div>
        <% } %>
  
        <% if (success) { %>
          <div class="bg-green-100 text-green-700 p-3 rounded mb-4 text-center">
            <%= success %>
          </div>
        <% } %>
  
        <form action="/reset-password" method="POST">
  
          <div class="mb-5">
            <label class="font-semibold block mb-1">Email</label>
            <input type="email" name="email" required
              class="w-full border-2 border-gray-300 rounded-xl px-4 py-3">
          </div>
  
          <div class="mb-6">
            <label class="font-semibold block mb-1">New Password</label>
            <input type="password" name="newPassword" required
              class="w-full border-2 border-gray-300 rounded-xl px-4 py-3">
          </div>
  
          <button type="submit"
            class="w-full bg-blue-950 text-white py-3 rounded-xl">
            Update Password
          </button>
  
        </form>
  
      </div>
  
    </div>
  
  