<style>
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .notif-card { animation: slideIn .3s ease both; }
</style>

<div class="px-6 md:px-10 py-10 bg-gray-100 min-h-screen">

  <!-- Search -->
  <div class="mb-8">
    <input id="hodNotifSearch" type="text"
           placeholder="Search notifications..."
           class="w-full border border-gray-300 rounded-xl px-6 py-4 bg-white focus:ring-2 focus:ring-green-700 focus:outline-none text-sm">
  </div>

  <%
    const rejections = notifications.filter(n => n.status === "FACULTY_REJECTED");
    const pending    = notifications.filter(n => n.status === "PENDING");
    const approved   = notifications.filter(n => n.status === "APPROVED");
  %>

  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">HOD Notifications</h2>
      <p class="text-sm text-gray-500 mt-0.5">Faculty rejections, new requests, and updates</p>
    </div>
    <% if (rejections.length > 0) { %>
      <span class="flex items-center gap-1.5 bg-red-100 text-red-700 text-sm font-semibold px-4 py-1.5 rounded-full">
        <span class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></span>
        <%= rejections.length %> Decline<%= rejections.length > 1 ? 's' : '' %>
      </span>
    <% } %>
  </div>

  <% if (notifications.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-2xl p-16 flex flex-col items-center text-center shadow-sm">
      <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-4">
        <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
        </svg>
      </div>
      <p class="font-semibold text-gray-500">No notifications</p>
      <p class="text-sm text-gray-400 mt-1">You'll see faculty responses and requests here.</p>
    </div>

  <% } else { %>

    <!-- Faculty Rejections -->
    <% if (rejections.length > 0) { %>
      <div class="mb-8">
        <h3 class="text-xs font-semibold text-red-600 uppercase tracking-widest mb-3 flex items-center gap-2">
          <span class="w-2 h-2 bg-red-500 rounded-full"></span>
          Faculty Declined Assignments
        </h3>
        <div class="space-y-3">
          <% rejections.forEach((n, i) => { %>
            <div class="notif-card bg-white border-2 border-red-100 rounded-2xl shadow-sm overflow-hidden"
                 style="animation-delay: <%= i * 50 %>ms">
              <div class="h-1 bg-gradient-to-r from-red-500 to-red-400"></div>
              <div class="p-5 flex items-start gap-4">
                <div class="w-10 h-10 bg-red-100 rounded-xl flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div class="flex-1 min-w-0">
                  <div class="flex items-start justify-between gap-3">
                    <div>
                      <p class="font-semibold text-gray-900 text-sm">
                        <%= n.faculty ? n.faculty.fullName : 'Faculty' %> declined an assignment
                      </p>
                      <p class="text-gray-500 text-sm mt-0.5">
                        Course: <span class="font-semibold text-gray-800"><%= n.courseName %></span>
                      </p>
                    </div>
                    <span class="shrink-0 bg-red-100 text-red-700 text-xs font-semibold px-3 py-0.5 rounded-full">Declined</span>
                  </div>
                  <% if (n.rejectionReason) { %>
                    <div class="mt-3 bg-gray-50 border border-gray-200 rounded-xl px-4 py-2.5 text-sm text-gray-600">
                      <span class="font-medium text-gray-500">Reason:</span> <%= n.rejectionReason %>
                    </div>
                  <% } else { %>
                    <p class="mt-2 text-xs text-gray-400 italic">No reason provided</p>
                  <% } %>
                  <div class="flex items-center gap-3 mt-3">
                    <p class="text-xs text-gray-400">
                      <%= n.updatedAt ? new Date(n.updatedAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—' %>
                    </p>
                    <a href="/faculty-members"
                       class="text-xs text-green-800 hover:underline font-medium">
                      Reassign &rarr;
                    </a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Pending Requests -->
    <% if (pending.length > 0) { %>
      <div class="mb-8">
        <h3 class="text-xs font-semibold text-orange-600 uppercase tracking-widest mb-3 flex items-center gap-2">
          <span class="w-2 h-2 bg-orange-500 rounded-full animate-pulse"></span>
          Pending Requests from Faculty
        </h3>
        <div class="space-y-3">
          <% pending.forEach((n, i) => { %>
            <div class="notif-card bg-white border border-orange-100 rounded-2xl shadow-sm p-5 flex items-center justify-between gap-4"
                 style="animation-delay: <%= i * 50 %>ms">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium text-gray-800 text-sm">
                    <%= n.faculty ? n.faculty.fullName : '—' %> requested <span class="font-semibold"><%= n.courseName %></span>
                  </p>
                  <p class="text-xs text-gray-400 mt-0.5">AI Match: <span class="text-green-700 font-semibold"><%= n.matchScore %>%</span></p>
                </div>
              </div>
              <div class="flex gap-2 shrink-0">
                <form action="/approve/<%= n._id %>" method="POST">
                  <button class="bg-green-700 hover:bg-green-800 text-white text-xs font-semibold px-4 py-2 rounded-xl transition">Approve</button>
                </form>
                <form action="/reject/<%= n._id %>" method="POST">
                  <button class="bg-gray-200 hover:bg-gray-300 text-gray-700 text-xs font-semibold px-4 py-2 rounded-xl transition">Reject</button>
                </form>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- Approved (recent) -->
    <% if (approved.length > 0) { %>
      <div>
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Recently Approved</h3>
        <div class="space-y-2">
          <% approved.slice(0, 6).forEach((n, i) => { %>
            <div class="notif-card bg-white border border-gray-100 rounded-2xl shadow-sm p-4 flex items-center gap-4"
                 style="animation-delay: <%= i * 40 %>ms">
              <span class="w-2.5 h-2.5 rounded-full bg-green-500 shrink-0"></span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-800 truncate">
                  <%= n.faculty ? n.faculty.fullName : '—' %> — <%= n.courseName %>
                </p>
              </div>
              <span class="shrink-0 bg-green-100 text-green-700 text-xs font-semibold px-3 py-0.5 rounded-full">Approved</span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

  <% } %>
</div>

<script>
  document.getElementById("hodNotifSearch").addEventListener("keyup", function() {
    const val = this.value.toLowerCase();
    document.querySelectorAll(".notif-card").forEach(card => {
      card.style.display = card.innerText.toLowerCase().includes(val) ? "" : "none";
    });
  });
</script>
