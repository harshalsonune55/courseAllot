<div class="px-6 md:px-16 py-10 bg-gray-100 min-h-screen">

  <!-- Search -->
  <div class="mb-8">
    <input id="dashboardSearch" type="text"
      placeholder="Search courses..."
      class="w-full border border-gray-300 rounded-xl px-6 py-4 bg-white focus:ring-2 focus:ring-blue-600 focus:outline-none text-sm">
  </div>

  <h2 class="text-2xl font-bold text-gray-800 mb-6">Dashboard</h2>

  <!-- 4 Stat Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-10">

    <!-- Approved Courses -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
      <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center mb-3">
        <svg class="w-5 h-5 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Approved Courses</p>
      <h3 class="text-3xl font-bold text-gray-900 mt-1"><%= data.stats.approvedCourses %></h3>
    </div>

    <!-- Pending Requests -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
      <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center mb-3">
        <svg class="w-5 h-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
      </div>
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Pending Requests</p>
      <h3 class="text-3xl font-bold text-gray-900 mt-1"><%= data.stats.pendingRequests %></h3>
    </div>

    <!-- AI Match -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
      <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center mb-3">
        <svg class="w-5 h-5 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
        </svg>
      </div>
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">AI Match</p>
      <h3 class="text-3xl font-bold text-gray-900 mt-1">
        <%= data.stats.aiMatch %><span class="text-lg font-medium text-gray-400">%</span>
      </h3>
    </div>

    <!-- CV Status -->
    <div class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm">
      <div class="w-10 h-10 <%= data.stats.cvUploaded ? 'bg-green-100' : 'bg-gray-100' %> rounded-xl flex items-center justify-center mb-3">
        <svg class="w-5 h-5 <%= data.stats.cvUploaded ? 'text-green-700' : 'text-gray-400' %>" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </div>
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">CV Status</p>
      <h3 class="text-lg font-bold mt-1 <%= data.stats.cvUploaded ? 'text-green-700' : 'text-gray-400' %>">
        <%= data.stats.cvUploaded ? 'Uploaded' : 'Not Uploaded' %>
      </h3>
      <% if (!data.stats.cvUploaded) { %>
        <a href="/upload-cv" class="text-xs text-blue-700 hover:underline mt-1 inline-block">Upload now &rarr;</a>
      <% } %>
    </div>

  </div>

  <!-- AI Recommendations -->
  <div class="bg-white rounded-2xl p-8 shadow-sm border border-gray-200">

    <div class="flex items-center justify-between mb-6">
      <h3 class="text-lg font-semibold text-gray-800">AI Recommendations</h3>
      <a href="/preferences" class="text-sm text-blue-700 hover:underline font-medium">Set Preferences &rarr;</a>
    </div>

    <% if (data.recommendations && data.recommendations.length > 0) { %>

      <div class="space-y-3">
      <% data.recommendations.forEach(course => {
          const realRequest = data.requests.find(r => r.courseName === course.course);
      %>
        <div class="dashboard-card bg-gray-50 p-5 rounded-xl flex justify-between items-center border border-gray-100">
          <div>
            <p class="font-medium text-gray-800"><%= course.course %></p>
            <p class="text-green-700 text-sm mt-0.5">AI Match: <%= course.score %>%</p>
          </div>

          <% if (realRequest) { %>
            <% if (realRequest.status === "APPROVED") { %>
              <span class="bg-green-100 text-green-700 px-4 py-1.5 rounded-full text-xs font-semibold">Approved</span>
            <% } else if (realRequest.status === "REJECTED") { %>
              <span class="bg-red-100 text-red-700 px-4 py-1.5 rounded-full text-xs font-semibold">Rejected</span>
            <% } else if (realRequest.status === "HOD_ASSIGNED") { %>
              <span class="bg-orange-100 text-orange-700 px-4 py-1.5 rounded-full text-xs font-semibold">Action Needed</span>
            <% } else { %>
              <span class="bg-gray-200 text-gray-600 px-4 py-1.5 rounded-full text-xs font-semibold">Pending</span>
            <% } %>
          <% } else { %>
            <a href="/allocations"
               class="bg-blue-950 text-white px-4 py-1.5 rounded-full text-xs font-semibold hover:bg-blue-900 transition">
              Request
            </a>
          <% } %>
        </div>
      <% }) %>
      </div>

    <% } else { %>
      <div class="bg-yellow-50 border border-yellow-200 text-yellow-900 p-6 rounded-xl text-sm">
        No AI recommendations yet.
        <a href="/upload-cv" class="font-semibold underline ml-1">Upload your CV</a> to get started.
      </div>
    <% } %>

  </div>

</div>

<script>
  document.getElementById("dashboardSearch").addEventListener("keyup", function () {
    const value = this.value.toLowerCase();
    document.querySelectorAll(".dashboard-card").forEach(card => {
      card.style.display = card.innerText.toLowerCase().includes(value) ? "flex" : "none";
    });
  });
</script>
