<style>
  @keyframes slideIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .notif-card { animation: slideIn .3s ease both; }
</style>

<div class="px-6 md:px-16 py-10 bg-gray-100 min-h-screen">

  <!-- Search -->
  <div class="mb-8">
    <input id="notifSearch" type="text"
           placeholder="Search notifications..."
           class="w-full border border-gray-300 rounded-xl px-6 py-4 bg-white focus:ring-2 focus:ring-blue-600 focus:outline-none text-sm">
  </div>

  <%
    const hodAssigned  = data.requests.filter(r => r.status === "HOD_ASSIGNED");
    const past         = data.requests.filter(r => r.status !== "HOD_ASSIGNED");
    const pendingCount = hodAssigned.length;
  %>

  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">Notifications</h2>
      <p class="text-sm text-gray-500 mt-0.5">Course assignments and status updates</p>
    </div>
    <% if (pendingCount > 0) { %>
      <span class="flex items-center gap-1.5 bg-orange-100 text-orange-700 text-sm font-semibold px-4 py-1.5 rounded-full">
        <span class="w-2 h-2 bg-orange-500 rounded-full animate-pulse"></span>
        <%= pendingCount %> Action Required
      </span>
    <% } %>
  </div>

  <% if (data.requests.length === 0) { %>
    <div class="bg-white border border-gray-200 rounded-2xl p-16 flex flex-col items-center text-center shadow-sm">
      <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-4">
        <svg class="w-8 h-8 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
        </svg>
      </div>
      <p class="font-semibold text-gray-500">No notifications yet</p>
      <p class="text-sm text-gray-400 mt-1">You'll see course assignments and updates here.</p>
    </div>
  <% } else { %>

    <!-- ACTION REQUIRED -->
    <% if (hodAssigned.length > 0) { %>
      <div class="mb-8">
        <h3 class="text-xs font-semibold text-orange-600 uppercase tracking-widest mb-3 flex items-center gap-2">
          <span class="w-2 h-2 bg-orange-500 rounded-full animate-pulse"></span>
          Action Required
        </h3>
        <div class="space-y-4">
          <% hodAssigned.forEach((req, i) => { %>
            <div class="notification-card notif-card bg-white border-2 border-orange-200 rounded-2xl shadow-sm overflow-hidden"
                 style="animation-delay: <%= i * 60 %>ms">
              <div class="h-1 bg-gradient-to-r from-orange-400 to-amber-400"></div>
              <div class="p-6">
                <div class="flex items-start gap-4">
                  <div class="w-11 h-11 rounded-xl bg-orange-100 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-3">
                      <div>
                        <p class="font-semibold text-gray-900 text-base">HOD assigned you a course</p>
                        <p class="text-gray-500 text-sm mt-0.5">
                          You have been assigned
                          <span class="font-semibold text-gray-800"><%= req.courseName %></span>
                          by your HOD. Please review and respond.
                        </p>
                      </div>
                      <span class="shrink-0 bg-orange-100 text-orange-700 text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap">
                        Awaiting Response
                      </span>
                    </div>

                    <% if (req.hodReply && req.hodReply !== "Assigned by HOD") { %>
                      <div class="mt-3 bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-600">
                        <span class="font-medium text-gray-500">HOD Note:</span> <%= req.hodReply %>
                      </div>
                    <% } %>

                    <div class="flex items-center gap-4 mt-3 text-xs text-gray-400">
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <%= req.createdAt ? new Date(req.createdAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—' %>
                      </span>
                      <span class="bg-blue-100 text-blue-700 px-2 py-0.5 rounded font-medium"><%= req.courseName %></span>
                    </div>

                    <div class="flex gap-3 mt-5">
                      <!-- Accept -->
                      <form action="/faculty-accept/<%= req._id %>" method="POST" class="flex-1">
                        <button type="submit"
                                class="w-full flex items-center justify-center gap-2 bg-green-700 hover:bg-green-800 text-white font-semibold py-2.5 rounded-xl text-sm transition">
                          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                          </svg>
                          Accept
                        </button>
                      </form>
                      <!-- Decline (opens reason modal) -->
                      <button type="button"
                              onclick="openRejectModal('<%= req._id %>', '<%= req.courseName %>')"
                              class="flex-1 flex items-center justify-center gap-2 bg-white hover:bg-red-50 text-red-600 border border-red-200 hover:border-red-400 font-semibold py-2.5 rounded-xl text-sm transition">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                        </svg>
                        Decline
                      </button>
                    </div>

                  </div>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- PAST NOTIFICATIONS -->
    <% if (past.length > 0) { %>
      <div>
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-widest mb-3">Earlier</h3>
        <div class="space-y-3">
          <% past.forEach((req, i) => { %>
            <%
              const isApproved = req.status === "APPROVED";
              const isRejected = req.status === "REJECTED";
              const isFacRej   = req.status === "FACULTY_REJECTED";

              let dotColor   = "bg-gray-400";
              let iconBg     = "bg-gray-100";
              let iconStroke = "#9ca3af";
              let badgeBg    = "bg-gray-100 text-gray-600";
              let badgeText  = "—";
              let title      = "";
              let subtitle   = "";

              if (isApproved && req.assignedByHOD) {
                dotColor   = "bg-green-500"; iconBg = "bg-green-100"; iconStroke = "#15803d";
                badgeBg    = "bg-green-100 text-green-700"; badgeText = "Accepted";
                title      = "You accepted the HOD assignment";
                subtitle   = "You are now assigned to teach " + req.courseName + ".";
              } else if (isApproved) {
                dotColor   = "bg-green-500"; iconBg = "bg-green-100"; iconStroke = "#15803d";
                badgeBg    = "bg-green-100 text-green-700"; badgeText = "Approved";
                title      = "Course allocation approved";
                subtitle   = "Your request for " + req.courseName + " was approved by the HOD.";
              } else if (isFacRej) {
                dotColor   = "bg-slate-400"; iconBg = "bg-slate-100"; iconStroke = "#64748b";
                badgeBg    = "bg-slate-100 text-slate-600"; badgeText = "Declined";
                title      = "You declined the assignment";
                subtitle   = "You declined the HOD's assignment for " + req.courseName + ".";
              } else if (isRejected) {
                dotColor   = "bg-red-500"; iconBg = "bg-red-100"; iconStroke = "#dc2626";
                badgeBg    = "bg-red-100 text-red-600"; badgeText = "Rejected";
                title      = "Course allocation rejected";
                subtitle   = "Your request for " + req.courseName + " was rejected.";
              }
            %>
            <div class="notification-card notif-card bg-white border border-gray-200 rounded-2xl shadow-sm p-5 flex items-start gap-4"
                 style="animation-delay: <%= i * 50 %>ms">
              <div class="mt-1.5 shrink-0">
                <span class="w-2.5 h-2.5 rounded-full <%= dotColor %> block"></span>
              </div>
              <div class="w-10 h-10 rounded-xl <%= iconBg %> flex items-center justify-center shrink-0">
                <% if (isApproved) { %>
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="<%= iconStroke %>" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                <% } else { %>
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="<%= iconStroke %>" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                <% } %>
              </div>
              <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="font-semibold text-gray-800 text-sm"><%= title %></p>
                    <p class="text-gray-500 text-sm mt-0.5"><%= subtitle %></p>
                  </div>
                  <span class="shrink-0 text-xs font-semibold px-3 py-0.5 rounded-full <%= badgeBg %>"><%= badgeText %></span>
                </div>
                <% if (req.hodReply && !isFacRej) { %>
                  <p class="mt-2 text-xs text-gray-400 bg-gray-50 rounded-lg px-3 py-2">
                    <span class="font-medium">HOD:</span> <%= req.hodReply %>
                  </p>
                <% } %>
                <% if (isFacRej && req.rejectionReason) { %>
                  <p class="mt-2 text-xs text-gray-400 bg-gray-50 rounded-lg px-3 py-2">
                    <span class="font-medium">Your reason:</span> <%= req.rejectionReason %>
                  </p>
                <% } %>
                <p class="text-xs text-gray-400 mt-2">
                  <%= req.updatedAt ? new Date(req.updatedAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—' %>
                </p>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>

  <% } %>
</div>

<!-- ===== REJECT WITH REASON MODAL ===== -->
<div id="rejectReasonModal"
     class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center hidden z-50"
     onclick="if(event.target===this)closeRejectModal()">
  <div class="bg-white w-[480px] rounded-2xl shadow-2xl overflow-hidden">
    <div class="h-1 bg-gradient-to-r from-red-500 to-red-400"></div>
    <div class="p-6">
      <h3 class="text-lg font-bold text-gray-900 mb-1">Decline Assignment</h3>
      <p class="text-sm text-gray-500 mb-5">
        Declining: <span id="rejectCourseName" class="font-semibold text-gray-800"></span>
      </p>
      <form id="rejectForm" method="POST">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 mb-1.5">Reason for declining <span class="text-gray-400 font-normal">(optional)</span></label>
          <textarea name="rejectionReason" rows="3"
                    placeholder="e.g. I don't have sufficient expertise in this area..."
                    class="w-full border border-gray-300 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-400 resize-none"></textarea>
        </div>
        <div class="flex gap-3">
          <button type="button" onclick="closeRejectModal()"
                  class="flex-1 border border-gray-300 text-gray-700 py-2.5 rounded-xl text-sm font-medium hover:bg-gray-50 transition">
            Cancel
          </button>
          <button type="submit"
                  class="flex-1 bg-red-600 hover:bg-red-700 text-white py-2.5 rounded-xl text-sm font-semibold transition">
            Confirm Decline
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.getElementById("notifSearch").addEventListener("keyup", function() {
    const val = this.value.toLowerCase();
    document.querySelectorAll(".notification-card").forEach(card => {
      card.style.display = card.innerText.toLowerCase().includes(val) ? "" : "none";
    });
  });

  function openRejectModal(reqId, courseName) {
    document.getElementById("rejectCourseName").innerText = courseName;
    document.getElementById("rejectForm").action = "/faculty-reject/" + reqId;
    document.getElementById("rejectReasonModal").classList.remove("hidden");
  }

  function closeRejectModal() {
    document.getElementById("rejectReasonModal").classList.add("hidden");
  }
</script>
