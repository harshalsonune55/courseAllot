<style>
  /* ---------- animations ---------- */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes progressBar {
    from { width: 0%; }
    to   { width: 100%; }
  }
  @keyframes pulse-ring {
    0%   { transform: scale(1);   opacity: 1; }
    80%  { transform: scale(1.6); opacity: 0; }
    100% { transform: scale(1.6); opacity: 0; }
  }
  @keyframes tick-draw {
    from { stroke-dashoffset: 60; }
    to   { stroke-dashoffset: 0;  }
  }
  @keyframes score-fill {
    from { stroke-dashoffset: 251; }
  }
  @keyframes float-up {
    0%   { opacity: 0; transform: translateY(6px);  }
    40%  { opacity: 1; }
    100% { opacity: 0; transform: translateY(-30px); }
  }

  .fade-slide-up { animation: fadeSlideUp .45s ease both; }

  /* drop-zone */
  #dropZone {
    transition: border-color .25s, background .25s, transform .15s;
  }
  #dropZone.drag-over {
    border-color: #2563eb;
    background: #eff6ff;
    transform: scale(1.01);
  }

  /* progress */
  #progressWrap { display: none; }
  #progressBar  { animation: progressBar 2.2s cubic-bezier(.4,0,.2,1) forwards; }

  /* tick */
  .tick-circle {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .tick-circle .ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 3px solid #16a34a;
    animation: pulse-ring 1.4s cubic-bezier(.4,0,.2,1) 1;
  }
  .tick-svg { display: block; }
  .tick-path {
    stroke-dasharray: 60;
    stroke-dashoffset: 60;
    animation: tick-draw .55s ease .15s forwards;
  }

  /* score ring */
  .score-ring-bg   { stroke: #e5e7eb; }
  .score-ring-fill {
    stroke: #16a34a;
    stroke-linecap: round;
    transform-origin: 50% 50%;
    transform: rotate(-90deg);
    transition: stroke-dashoffset 1.4s cubic-bezier(.4,0,.2,1) .3s;
  }

  /* floating particles on success */
  .particle {
    position: absolute;
    font-size: 18px;
    pointer-events: none;
    animation: float-up 1.2s ease forwards;
  }
</style>

<div class="px-6 md:px-16 py-10 bg-gray-100 min-h-screen">

  <!-- search bar -->
  <div class="mb-8">
    <input
      type="text"
      placeholder="Search courses, faculty, allocations..."
      class="w-full border border-gray-300 rounded-xl px-6 py-4 focus:ring-2 focus:ring-blue-600 focus:outline-none bg-white"
    />
  </div>

  <!-- page title -->
  <h2 class="text-2xl font-bold text-gray-800 mb-6">
    Upload CV <span class="text-green-600">✨</span>
  </h2>

  <!-- ====== MAIN CARD ====== -->
  <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">

    <!-- card header -->
    <div class="px-8 pt-8 pb-4">
      <h3 class="text-xl font-semibold text-gray-800">
        AI-Powered CV Analysis <span class="text-purple-500">✨</span>
      </h3>
      <p class="text-gray-500 text-sm mt-1">
        Upload your CV and our AI will automatically analyse your qualifications,
        extract skills, and recommend suitable courses.
      </p>
    </div>

    <div class="px-8 pb-10">

      <!-- ===== SUCCESS STATE ===== -->
      <% if (success && data.user) { %>
      <div class="fade-slide-up">

        <!-- tick + score row -->
        <div class="flex flex-col sm:flex-row items-center gap-10 mt-6">

          <!-- animated tick -->
          <div class="flex flex-col items-center gap-3">
            <div class="tick-circle w-24 h-24">
              <span class="ring"></span>
              <svg class="tick-svg" width="96" height="96" viewBox="0 0 96 96">
                <circle cx="48" cy="48" r="40" fill="#f0fdf4" stroke="#16a34a" stroke-width="3"/>
                <polyline
                  class="tick-path"
                  points="28,50 42,64 68,34"
                  fill="none"
                  stroke="#16a34a"
                  stroke-width="5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </div>
            <p class="text-green-700 font-semibold text-lg text-center">CV Uploaded Successfully!</p>
          </div>

          <!-- score ring -->
          <% const score = data.user.authenticityScore || 0; %>
          <div class="flex flex-col items-center gap-2">
            <div class="relative w-28 h-28">
              <svg width="112" height="112" viewBox="0 0 112 112">
                <circle class="score-ring-bg" cx="56" cy="56" r="40" fill="none" stroke-width="8"/>
                <circle
                  class="score-ring-fill"
                  cx="56" cy="56" r="40"
                  fill="none"
                  stroke-width="8"
                  stroke-dasharray="251"
                  id="scoreRingFill"
                  style="stroke-dashoffset: <%= Math.round(251 - (score / 100) * 251) %>;"
                />
              </svg>
              <div class="absolute inset-0 flex flex-col items-center justify-center">
                <span class="text-2xl font-bold text-gray-800" id="scoreNumber">0</span>
                <span class="text-xs text-gray-400">CV Score</span>
              </div>
            </div>
            <p class="text-sm text-gray-500 font-medium">CV Quality Score</p>
          </div>

          <!-- details -->
          <div class="flex-1 bg-green-50 border border-green-200 rounded-2xl p-5 text-sm text-green-900 space-y-2">
            <div class="flex justify-between">
              <span class="text-gray-500">Status</span>
              <span class="font-semibold text-green-700">Approved ✔</span>
            </div>
            <div class="flex justify-between border-t border-green-100 pt-2">
              <span class="text-gray-500">CV Quality Score</span>
              <span class="font-semibold"><%= score %>%</span>
            </div>
            <div class="flex justify-between border-t border-green-100 pt-2">
              <span class="text-gray-500">Uploaded on</span>
              <span class="font-semibold"><%= new Date(data.user.cvUploadedAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %></span>
            </div>
            <% if (data.user.skills && data.user.skills.length > 0) { %>
            <div class="border-t border-green-100 pt-2">
              <span class="text-gray-500 block mb-1">Skills detected</span>
              <div class="flex flex-wrap gap-1">
                <% data.user.skills.slice(0,6).forEach(s => { %>
                  <span class="bg-green-200 text-green-900 px-2 py-0.5 rounded-full text-xs"><%= s %></span>
                <% }); %>
              </div>
            </div>
            <% } %>
          </div>
        </div>

        <!-- re-upload link -->
        <p class="text-center text-sm text-gray-400 mt-8">
          Want to update your CV?
          <a href="#" onclick="showUploadForm()" class="text-blue-600 hover:underline font-medium">Upload again</a>
        </p>

      </div>
      <% } %>

      <!-- ===== REJECTED STATE ===== -->
      <% if (rejected) { %>
      <div class="fade-slide-up mt-6 bg-red-50 border border-red-200 rounded-2xl p-6 flex items-start gap-4">
        <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center text-2xl flex-shrink-0">✗</div>
        <div>
          <p class="font-semibold text-red-700 text-lg">CV Rejected</p>
          <p class="text-red-600 text-sm mt-1">
            The uploaded file does not appear to be a valid CV. Please upload a proper PDF or DOCX CV.
          </p>
          <% if (data.user && data.user.cvUploadedAt) { %>
          <p class="text-red-400 text-xs mt-2">Uploaded on: <%= new Date(data.user.cvUploadedAt).toLocaleDateString() %></p>
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- ===== ERROR STATE ===== -->
      <% if (error) { %>
      <div class="fade-slide-up mt-6 bg-yellow-50 border border-yellow-200 rounded-2xl p-4 flex items-center gap-3 text-yellow-800 text-sm">
        <span class="text-xl">⚠</span>
        Please upload a valid PDF, DOC, or DOCX file (max 1 MB).
      </div>
      <% } %>

      <!-- ===== UPLOAD FORM (hidden when success) ===== -->
      <div id="uploadFormSection" class="<%= success ? 'hidden' : '' %>">

        <form action="/upload-cv" method="POST" enctype="multipart/form-data" id="cvForm">
          <input type="file" name="cv" accept=".pdf,.doc,.docx" class="hidden" id="cvInput" required>

          <!-- drop zone -->
          <div id="dropZone"
               class="mt-6 border-2 border-dashed border-gray-300 rounded-2xl p-12 text-center cursor-pointer select-none"
               onclick="document.getElementById('cvInput').click()"
               ondragover="handleDragOver(event)"
               ondragleave="handleDragLeave(event)"
               ondrop="handleDrop(event)">

            <!-- default icon -->
            <div id="dzIcon" class="flex justify-center mb-4">
              <div class="w-16 h-16 rounded-2xl bg-blue-50 flex items-center justify-center">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                  <line x1="12" y1="18" x2="12" y2="12"/>
                  <polyline points="9 15 12 12 15 15"/>
                </svg>
              </div>
            </div>

            <p id="dzTitle" class="font-semibold text-gray-700 text-lg">Drop your CV here</p>
            <p id="dzSub"   class="text-gray-400 text-sm mt-1">or click to browse — PDF, DOC, DOCX · max 1 MB</p>

            <!-- file chosen preview (hidden by default) -->
            <div id="filePreview" class="hidden mt-5 flex items-center justify-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                  <polyline points="14 2 14 8 20 8"/>
                </svg>
              </div>
              <div class="text-left">
                <p id="fileName"   class="font-medium text-gray-700 text-sm"></p>
                <p id="fileSize"   class="text-gray-400 text-xs"></p>
              </div>
              <button type="button" onclick="clearFile(event)"
                class="ml-2 w-6 h-6 rounded-full bg-gray-200 text-gray-500 hover:bg-red-100 hover:text-red-500 flex items-center justify-center text-sm transition">
                ×
              </button>
            </div>
          </div>

          <!-- progress bar (shown during submit) -->
          <div id="progressWrap" class="mt-5">
            <div class="flex justify-between text-xs text-gray-500 mb-1">
              <span>Uploading & analysing…</span>
              <span id="progressPct">0%</span>
            </div>
            <div class="w-full h-2.5 bg-gray-200 rounded-full overflow-hidden">
              <div id="progressBar" class="h-full bg-gradient-to-r from-blue-500 to-green-500 rounded-full" style="width:0%"></div>
            </div>
          </div>

          <!-- submit button -->
          <div class="mt-7 flex justify-center">
            <button type="submit" id="submitBtn"
              class="inline-flex items-center gap-2 bg-blue-950 text-white px-10 py-3.5 rounded-xl font-medium
                     opacity-50 cursor-not-allowed transition hover:bg-blue-900 disabled:opacity-50"
              disabled>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4l3 3"/>
              </svg>
              Submit for AI Analysis
            </button>
          </div>

        </form>
      </div>
      <!-- end upload form -->

    </div>
    <!-- end card body -->
  </div>
  <!-- end main card -->

</div>

<script>
  /* ---- state ---- */
  const cvInput    = document.getElementById("cvInput");
  const dropZone   = document.getElementById("dropZone");
  const dzTitle    = document.getElementById("dzTitle");
  const dzSub      = document.getElementById("dzSub");
  const dzIcon     = document.getElementById("dzIcon");
  const filePreview= document.getElementById("filePreview");
  const fileName   = document.getElementById("fileName");
  const fileSize   = document.getElementById("fileSize");
  const submitBtn  = document.getElementById("submitBtn");
  const cvForm     = document.getElementById("cvForm");
  const progressWrap = document.getElementById("progressWrap");
  const progressBar  = document.getElementById("progressBar");
  const progressPct  = document.getElementById("progressPct");

  /* ---- drag-and-drop ---- */
  function handleDragOver(e) {
    e.preventDefault();
    dropZone.classList.add("drag-over");
  }
  function handleDragLeave(e) {
    dropZone.classList.remove("drag-over");
  }
  function handleDrop(e) {
    e.preventDefault();
    dropZone.classList.remove("drag-over");
    const files = e.dataTransfer.files;
    if (files.length) applyFile(files[0]);
  }

  /* ---- file input change ---- */
  cvInput.addEventListener("change", function() {
    if (this.files.length) applyFile(this.files[0]);
  });

  function applyFile(file) {
    /* show preview */
    dzTitle.textContent = "File selected";
    dzSub.textContent   = "";
    dzIcon.innerHTML    = "";          /* clear default icon */
    filePreview.classList.remove("hidden");
    fileName.textContent = file.name;
    fileSize.textContent = formatBytes(file.size);

    /* enable submit */
    submitBtn.disabled = false;
    submitBtn.classList.remove("opacity-50", "cursor-not-allowed");

    /* style drop zone */
    dropZone.classList.remove("border-gray-300");
    dropZone.classList.add("border-blue-500", "bg-blue-50");

    /* attach file to input if dropped */
    if (cvInput.files.length === 0) {
      const dt = new DataTransfer();
      dt.items.add(file);
      cvInput.files = dt.files;
    }
  }

  function clearFile(e) {
    e.stopPropagation();
    cvInput.value = "";
    filePreview.classList.add("hidden");
    dzTitle.textContent = "Drop your CV here";
    dzSub.textContent   = "or click to browse — PDF, DOC, DOCX · max 1 MB";
    dzIcon.innerHTML = `
      <div class="w-16 h-16 rounded-2xl bg-blue-50 flex items-center justify-center">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="12" y1="18" x2="12" y2="12"/>
          <polyline points="9 15 12 12 15 15"/>
        </svg>
      </div>`;
    dropZone.classList.remove("border-blue-500", "bg-blue-50");
    dropZone.classList.add("border-gray-300");
    submitBtn.disabled = true;
    submitBtn.classList.add("opacity-50", "cursor-not-allowed");
  }

  /* ---- submit: show progress ---- */
  if (cvForm) {
    cvForm.addEventListener("submit", function() {
      submitBtn.disabled = true;
      progressWrap.style.display = "block";

      let pct = 0;
      const interval = setInterval(() => {
        pct = Math.min(pct + Math.random() * 8 + 2, 92);
        progressBar.style.width = pct + "%";
        progressPct.textContent = Math.round(pct) + "%";
      }, 180);

      /* when page unloads (redirect incoming) fill to 100 */
      window.addEventListener("beforeunload", () => {
        clearInterval(interval);
        progressBar.style.width = "100%";
        progressPct.textContent = "100%";
      });
    });
  }

  /* ---- score counter animation ---- */
  const scoreEl = document.getElementById("scoreNumber");
  const ringEl  = document.getElementById("scoreRingFill");
  if (scoreEl && ringEl) {
    const target = parseInt("<%= (success && data.user) ? (data.user.authenticityScore || 0) : 0 %>") || 0;
    let current = 0;
    const step = target / 60;
    const timer = setInterval(() => {
      current = Math.min(current + step, target);
      scoreEl.textContent = Math.round(current) + "%";
      if (current >= target) clearInterval(timer);
    }, 20);
  }

  /* ---- show upload form (re-upload link) ---- */
  function showUploadForm() {
    document.getElementById("uploadFormSection").classList.remove("hidden");
  }

  /* ---- helper ---- */
  function formatBytes(bytes) {
    if (bytes < 1024)       return bytes + " B";
    if (bytes < 1048576)    return (bytes / 1024).toFixed(1) + " KB";
    return (bytes / 1048576).toFixed(1) + " MB";
  }
</script>
