<div class="px-6 md:px-12 py-10 bg-gray-100 min-h-screen">

  <!-- Search -->
  <div class="mb-8">
    <input id="allocSearch" type="text"
           placeholder="Search by faculty name, course..."
           class="w-full border border-gray-300 rounded-xl px-6 py-4 bg-white focus:ring-2 focus:ring-green-700 focus:outline-none text-sm">
  </div>

  <!-- Page title -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-gray-900">My Allotments</h2>
      <p class="text-sm text-gray-500 mt-0.5">All course allotments approved by you</p>
    </div>
    <span class="bg-blue-100 text-blue-800 text-sm font-semibold px-4 py-1.5 rounded-full">
      <%= allotments.length %> Total
    </span>
  </div>

  <!-- Stats row -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <%
      const uniqueFaculty  = new Set(allotments.map(a => a.faculty?._id?.toString())).size;
      const uniqueCourses  = new Set(allotments.map(a => a.courseName)).size;
      const acceptedCount  = allotments.filter(a => a.status === "APPROVED").length;
      const pendingResp    = allotments.filter(a => a.status === "HOD_ASSIGNED").length;
      const declinedCount  = allotments.filter(a => a.status === "FACULTY_REJECTED").length;
    %>
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Total Assigned</p>
      <p class="text-3xl font-bold text-gray-900 mt-1"><%= allotments.length %></p>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Accepted</p>
      <p class="text-3xl font-bold text-green-700 mt-1"><%= acceptedCount %></p>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Awaiting Response</p>
      <p class="text-3xl font-bold text-orange-500 mt-1"><%= pendingResp %></p>
    </div>
    <div class="bg-white rounded-2xl p-5 border border-gray-200 shadow-sm">
      <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Declined</p>
      <p class="text-3xl font-bold text-red-500 mt-1"><%= declinedCount %></p>
    </div>
  </div>

  <!-- Table card -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <h3 class="font-semibold text-gray-800">Allotment Records</h3>
      <span class="text-xs text-gray-400"><%= allotments.length %> records</span>
    </div>

    <% if (allotments.length === 0) { %>
      <div class="flex flex-col items-center justify-center py-20 text-center">
        <div class="w-16 h-16 bg-gray-100 rounded-2xl flex items-center justify-center mb-4">
          <svg class="w-8 h-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
        </div>
        <p class="font-semibold text-gray-600">No allotments yet</p>
        <p class="text-sm text-gray-400 mt-1">Approve requests or assign courses from the Faculty page.</p>
        <a href="/faculty-members" class="mt-4 text-sm text-green-700 hover:underline font-medium">Go to Faculty →</a>
      </div>

    <% } else { %>

      <!-- Desktop table -->
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-100 text-gray-500 text-xs uppercase tracking-wide">
              <th class="px-6 py-3 text-left font-medium">#</th>
              <th class="px-6 py-3 text-left font-medium">Faculty</th>
              <th class="px-6 py-3 text-left font-medium">Department</th>
              <th class="px-6 py-3 text-left font-medium">Course</th>
              <th class="px-6 py-3 text-left font-medium">Score</th>
              <th class="px-6 py-3 text-left font-medium">Type</th>
              <th class="px-6 py-3 text-left font-medium">Date</th>
              <th class="px-6 py-3 text-left font-medium">Remark</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-50" id="allocTableBody">
            <% allotments.forEach((a, i) => { %>
              <tr class="alloc-row hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 text-gray-400 font-medium"><%= i + 1 %></td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-900 to-blue-600 text-white flex items-center justify-center text-xs font-bold shrink-0">
                      <%= a.faculty?.fullName ? a.faculty.fullName.charAt(0).toUpperCase() : '?' %>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-800"><%= a.faculty?.fullName || 'Unknown' %></p>
                      <p class="text-xs text-gray-400"><%= a.faculty?.email || '' %></p>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 text-gray-600"><%= a.faculty?.department || '—' %></td>
                <td class="px-6 py-4">
                  <span class="bg-blue-50 text-blue-800 px-3 py-1 rounded-lg font-medium text-xs"><%= a.courseName %></span>
                </td>
                <td class="px-6 py-4">
                  <div class="flex items-center gap-1.5">
                    <div class="w-16 h-1.5 bg-gray-200 rounded-full overflow-hidden">
                      <div class="h-full bg-green-600 rounded-full" style="width:<%= Math.min(a.matchScore, 100) %>%"></div>
                    </div>
                    <span class="text-green-700 font-semibold text-xs"><%= a.matchScore %>%</span>
                  </div>
                </td>
                <td class="px-6 py-4">
                  <% if (a.status === "APPROVED") { %>
                    <span class="bg-green-100 text-green-700 px-2.5 py-0.5 rounded-full text-xs font-medium">Accepted</span>
                  <% } else if (a.status === "HOD_ASSIGNED") { %>
                    <span class="bg-orange-100 text-orange-600 px-2.5 py-0.5 rounded-full text-xs font-medium">Awaiting Response</span>
                  <% } else if (a.status === "FACULTY_REJECTED") { %>
                    <span class="bg-red-100 text-red-600 px-2.5 py-0.5 rounded-full text-xs font-medium">Declined</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-gray-500 text-xs whitespace-nowrap">
                  <%= a.updatedAt ? new Date(a.updatedAt).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) : '—' %>
                </td>
                <td class="px-6 py-4 text-gray-500 max-w-xs truncate">
                  <%= a.hodReply || a.comment || '—' %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div class="md:hidden divide-y divide-gray-100" id="allocCards">
        <% allotments.forEach((a, i) => { %>
          <div class="alloc-row px-5 py-5">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-gradient-to-br from-blue-900 to-blue-600 text-white flex items-center justify-center text-sm font-bold">
                  <%= a.faculty?.fullName ? a.faculty.fullName.charAt(0).toUpperCase() : '?' %>
                </div>
                <div>
                  <p class="font-semibold text-gray-800 text-sm"><%= a.faculty?.fullName || 'Unknown' %></p>
                  <p class="text-xs text-gray-400"><%= a.faculty?.department || '—' %></p>
                </div>
              </div>
              <% if (a.status === "APPROVED") { %>
                <span class="bg-green-700 text-white text-xs px-3 py-1 rounded-full">Accepted</span>
              <% } else if (a.status === "HOD_ASSIGNED") { %>
                <span class="bg-orange-100 text-orange-600 text-xs px-3 py-1 rounded-full">Awaiting</span>
              <% } else { %>
                <span class="bg-red-100 text-red-600 text-xs px-3 py-1 rounded-full">Declined</span>
              <% } %>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="bg-blue-50 text-blue-800 px-3 py-1 rounded-lg text-xs font-medium"><%= a.courseName %></span>
              <span class="text-green-700 font-semibold text-xs"><%= a.matchScore %>%</span>
            </div>
            <p class="text-xs text-gray-400 mt-2">
              <%= a.updatedAt ? new Date(a.updatedAt).toLocaleDateString() : '—' %>
              <% if (a.hodReply) { %> · <%= a.hodReply %><% } %>
            </p>
          </div>
        <% }); %>
      </div>

    <% } %>
  </div>
</div>

<script>
  document.getElementById("allocSearch").addEventListener("keyup", function() {
    const val = this.value.toLowerCase();
    document.querySelectorAll(".alloc-row").forEach(row => {
      row.style.display = row.innerText.toLowerCase().includes(val) ? "" : "none";
    });
  });
</script>
